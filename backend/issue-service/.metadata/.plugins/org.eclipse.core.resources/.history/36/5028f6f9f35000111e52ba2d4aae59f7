package com.issue_service.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.AutoConfigureMockMvc;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.context.annotation.Import;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.core.authority.SimpleGrantedAuthority;
import org.springframework.test.context.bean.override.mockito.MockitoBean;
import org.springframework.test.web.servlet.MockMvc;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.issue_service.config.SecurityConfig;
import com.issue_service.dto.request.CreateIssueDTO;
import com.issue_service.dto.request.IssueItemDTO;
import com.issue_service.dto.response.CurrentUser;
import com.issue_service.dto.response.IssueResponseDTO;
import com.issue_service.enums.IssueStatus;
import com.issue_service.enums.Role;
import com.issue_service.enums.Status;
import com.issue_service.exception.GlobalExceptionHandler;
import com.issue_service.secutity.CustomAccessDeniedHandler;
import com.issue_service.secutity.CustomAuthenticationEntryPoint;
import com.issue_service.secutity.JwtFilter;
import com.issue_service.secutity.JwtUtil;
import com.issue_service.service.IssueService;

@WebMvcTest(IssueController.class)
@AutoConfigureMockMvc
@Import({
        SecurityConfig.class,
        JwtFilter.class,
        JwtUtil.class,
        CustomAccessDeniedHandler.class,
        CustomAuthenticationEntryPoint.class,
        GlobalExceptionHandler.class
})
public class IssueServiceControllerTests {
	@Autowired
	private MockMvc mockMvc;

	@Autowired
	private ObjectMapper objectMapper;

	@MockitoBean
	private IssueService issueService;
	
	@MockitoBean
	private JwtUtil jwtUtil;
	
	private UsernamePasswordAuthenticationToken mockAuth(
	        Role role
	) {

	    CurrentUser currentUser =
	            CurrentUser.builder()
	                    .id("USR_001")
	                    .role(role)
	                    .status(Status.ACTIVE)
	                    .build();

	    return new UsernamePasswordAuthenticationToken(
	            currentUser,
	            null,
	            List.of(
	                    new SimpleGrantedAuthority(
	                            "ROLE_" + role.name()
	                    )
	            )
	    );
	}
	
	private CreateIssueDTO validCreateIssueDTO() {

	    return CreateIssueDTO.builder()
	            .requestId("REQ_001")
	            .items(List.of(
	                    new IssueItemDTO(
	                            "REQ_ITEM_1",
	                            2
	                    )
	            ))
	            .build();
	}
	
	private IssueResponseDTO responseDTO() {

	    return IssueResponseDTO.builder()
	            .issueId("ISSUE_001")
	            .requestId("REQ_001")
	            .status(IssueStatus.ISSUED)
	            .build();
	}
}
