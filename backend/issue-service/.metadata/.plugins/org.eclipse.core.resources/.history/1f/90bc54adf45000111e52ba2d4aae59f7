package com.issue_service.controller;

import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.post;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.jsonPath;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.status;
import static org.springframework.security.test.web.servlet.request.SecurityMockMvcRequestPostProcessors.authentication;

import java.util.List;

import org.junit.jupiter.api.Test;
import org.mockito.junit.jupiter.MockitoSettings;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.AutoConfigureMockMvc;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.context.annotation.Import;
import org.springframework.http.MediaType;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.core.authority.SimpleGrantedAuthority;
import org.springframework.test.context.bean.override.mockito.MockitoBean;
import org.springframework.test.web.servlet.MockMvc;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.issue_service.config.SecurityConfig;
import com.issue_service.dto.request.CreateIssueDTO;
import com.issue_service.dto.request.IssueItemDTO;
import com.issue_service.dto.response.CurrentUser;
import com.issue_service.dto.response.IssueResponseDTO;
import com.issue_service.enums.IssueStatus;
import com.issue_service.enums.Role;
import com.issue_service.enums.Status;
import com.issue_service.exception.ConflictException;
import com.issue_service.exception.GlobalExceptionHandler;
import com.issue_service.exception.ResourceNotFoundException;
import com.issue_service.exception.ServiceUnavailableException;
import com.issue_service.secutity.CustomAccessDeniedHandler;
import com.issue_service.secutity.CustomAuthenticationEntryPoint;
import com.issue_service.secutity.JwtFilter;
import com.issue_service.secutity.JwtUtil;
import com.issue_service.service.IssueService;

@WebMvcTest(IssueController.class)
@AutoConfigureMockMvc
@Import({
        SecurityConfig.class,
        JwtFilter.class,
        JwtUtil.class,
        CustomAccessDeniedHandler.class,
        CustomAuthenticationEntryPoint.class,
        GlobalExceptionHandler.class
})
public class IssueServiceControllerTests {
	@Autowired
	private MockMvc mockMvc;

	@Autowired
	private ObjectMapper objectMapper;

	@MockitoBean
	private IssueService issueService;
	
	@MockitoBean
	private JwtUtil jwtUtil;
	
	private UsernamePasswordAuthenticationToken mockAuth(
	        Role role
	) {

	    CurrentUser currentUser =
	            CurrentUser.builder()
	                    .id("USR_001")
	                    .role(role)
	                    .status(Status.ACTIVE)
	                    .build();

	    return new UsernamePasswordAuthenticationToken(
	            currentUser,
	            null,
	            List.of(
	                    new SimpleGrantedAuthority(
	                            "ROLE_" + role.name()
	                    )
	            )
	    );
	}
	
	private CreateIssueDTO validCreateIssueDTO() {

	    return CreateIssueDTO.builder()
	            .requestId("REQ_001")
	            .items(List.of(
	                    new IssueItemDTO(
	                            "REQ_ITEM_1",
	                            2
	                    )
	            ))
	            .build();
	}
	
	private IssueResponseDTO responseDTO() {

	    return IssueResponseDTO.builder()
	            .issueId("ISSUE_001")
	            .requestId("REQ_001")
	            .status(IssueStatus.ISSUED)
	            .build();
	}
	
	@Test
	void issueComponents_success() throws Exception {

	    when(issueService.issueComponents(any(), any()))
	            .thenReturn(responseDTO());

	    mockMvc.perform(
	            post("/issues")
	                    .with(authentication(
	                            mockAuth(Role.INSTRUCTOR)
	                    ))
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(
	                            objectMapper.writeValueAsString(
	                                    validCreateIssueDTO()
	                            )
	                    )
	    )
	    .andExpect(status().isOk())
	    .andExpect(
	            jsonPath("$.issueId")
	                    .value("ISSUE_001")
	    );

	    verify(issueService)
	            .issueComponents(any(), any());
	}
	
	@Test
	void issueComponents_studentForbidden() throws Exception {

	    mockMvc.perform(
	            post("/issues")
	                    .with(authentication(
	                            mockAuth(Role.STUDENT)
	                    ))
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(
	                            objectMapper.writeValueAsString(
	                                    validCreateIssueDTO()
	                            )
	                    )
	    )
	    .andExpect(status().isForbidden());

	    verify(issueService, never())
	            .issueComponents(any(), any());
	}
	
	@Test
	void issueComponents_validationFailure() throws Exception {

	    CreateIssueDTO dto =
	            CreateIssueDTO.builder()
	                    .build();

	    mockMvc.perform(
	            post("/issues")
	                    .with(authentication(
	                            mockAuth(Role.INSTRUCTOR)
	                    ))
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(
	                            objectMapper.writeValueAsString(dto)
	                    )
	    )
	    .andExpect(status().isBadRequest());

	    verify(issueService, never())
	            .issueComponents(any(), any());
	}
	
	@Test
	void getIssueById_success() throws Exception {

	    when(issueService.getIssueById(any(), any()))
	            .thenReturn(responseDTO());

	    mockMvc.perform(
	            get("/issues/ISSUE_001")
	                    .with(authentication(
	                            mockAuth(Role.STUDENT)
	                    ))
	    )
	    .andExpect(status().isOk())
	    .andExpect(
	            jsonPath("$.issueId")
	                    .value("ISSUE_001")
	    );

	    verify(issueService)
	            .getIssueById(any(), any());
	}
	
	@Test
	void getIssueById_unauthorized() throws Exception {

	    mockMvc.perform(
	            get("/issues/ISSUE_001")
	    )
	    .andExpect(status().isUnauthorized());

	    verify(issueService, never())
	            .getIssueById(any(), any());
	}
	
	@Test
	void getIssuesByRequestId_success() throws Exception {

	    when(issueService.getIssuesByRequestId(any(), any()))
	            .thenReturn(List.of(responseDTO()));

	    mockMvc.perform(
	            get("/issues/request/REQ_001")
	                    .with(authentication(
	                            mockAuth(Role.STUDENT)
	                    ))
	    )
	    .andExpect(status().isOk());

	    verify(issueService)
	            .getIssuesByRequestId(any(), any());
	}
	
	@Test
	void getAllIssues_instructorSuccess() throws Exception {

	    when(issueService.getAllIssues(any()))
	            .thenReturn(List.of(responseDTO()));

	    mockMvc.perform(
	            get("/issues")
	                    .with(authentication(
	                            mockAuth(Role.INSTRUCTOR)
	                    ))
	    )
	    .andExpect(status().isOk());

	    verify(issueService)
	            .getAllIssues(any());
	}
	
	@Test
	void getAllIssues_studentForbidden() throws Exception {

	    mockMvc.perform(
	            get("/issues")
	                    .with(authentication(
	                            mockAuth(Role.STUDENT)
	                    ))
	    )
	    .andExpect(status().isForbidden());

	    verify(issueService, never())
	            .getAllIssues(any());
	}
	
	@Test
	void getIssueById_notFound() throws Exception {

	    when(issueService.getIssueById(any(), any()))
	            .thenThrow(
	                    new ResourceNotFoundException(
	                            "Issue not found"
	                    )
	            );

	    mockMvc.perform(
	            get("/issues/ISSUE_001")
	                    .with(authentication(
	                            mockAuth(Role.STUDENT)
	                    ))
	    )
	    .andExpect(status().isNotFound())
	    .andExpect(
	            jsonPath("$.message")
	                    .value("Issue not found")
	    );
	}
	
	@Test
	void issueComponents_conflict() throws Exception {

	    when(issueService.issueComponents(any(), any()))
	            .thenThrow(
	                    new ConflictException(
	                            "Issuing exceeds approved limit"
	                    )
	            );

	    mockMvc.perform(
	            post("/issues")
	                    .with(authentication(
	                            mockAuth(Role.INSTRUCTOR)
	                    ))
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(
	                            objectMapper.writeValueAsString(
	                                    validCreateIssueDTO()
	                            )
	                    )
	    )
	    .andExpect(status().isConflict());
	}
	
	@Test
	void issueComponents_serviceUnavailable() throws Exception {

	    when(issueService.issueComponents(any(), any()))
	            .thenThrow(
	                    new ServiceUnavailableException(
	                            "Inventory service unavailable"
	                    )
	            );

	    mockMvc.perform(
	            post("/issues")
	                    .with(authentication(
	                            mockAuth(Role.INSTRUCTOR)
	                    ))
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(
	                            objectMapper.writeValueAsString(
	                                    validCreateIssueDTO()
	                            )
	                    )
	    )
	    .andExpect(status().isServiceUnavailable());
	}
	
	
}
