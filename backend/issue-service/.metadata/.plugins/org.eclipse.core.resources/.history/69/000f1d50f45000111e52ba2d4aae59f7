package com.issue_service.service.impl;

import java.time.LocalDateTime;
import java.util.HashSet;
import java.util.List;
import java.util.Map;
import java.util.Set;
import java.util.stream.Collectors;

import org.springframework.stereotype.Service;

import com.issue_service.dto.request.CreateIssueDTO;
import com.issue_service.dto.request.IssueItemDTO;
import com.issue_service.dto.response.BulkDeductRequestDTO;
import com.issue_service.dto.response.CurrentUser;
import com.issue_service.dto.response.DeductRequestDTO;
import com.issue_service.dto.response.IssueItemResponseDTO;
import com.issue_service.dto.response.IssueResponseDTO;
import com.issue_service.dto.response.RequestItemResponseDTO;
import com.issue_service.dto.response.RequestResponseDTO;
import com.issue_service.entity.Issue;
import com.issue_service.entity.IssueItem;
import com.issue_service.enums.IssueStatus;
import com.issue_service.enums.RequestStatus;
import com.issue_service.enums.Role;
import com.issue_service.enums.Status;
import com.issue_service.exception.BadRequestException;
import com.issue_service.exception.ConflictException;
import com.issue_service.exception.ResourceNotFoundException;
import com.issue_service.exception.ServiceUnavailableException;
import com.issue_service.exception.UnauthorizedException;
import com.issue_service.repository.IssueRepository;
import com.issue_service.service.InventoryClient;
import com.issue_service.service.IssueService;
import com.issue_service.service.RequestClient;

import feign.FeignException;
import jakarta.transaction.Transactional;
import lombok.RequiredArgsConstructor;

@RequiredArgsConstructor
@Service
public class IssueServiceImpl implements IssueService {
	
	private final IssueRepository issueRepository;
	
	private final InventoryClient inventoryClient;
	
	private final RequestClient requestClient;
	
	@Override
	@Transactional
	public IssueResponseDTO issueComponents(CreateIssueDTO dto, CurrentUser currentUser) {

		validateInstructor(currentUser);
		
	    // 🔒 1. Validate input
	    if (dto.getItems() == null || dto.getItems().isEmpty()) {
	        throw new BadRequestException("Issue items cannot be empty");
	    }

	    // 🔒 2. Prevent duplicate requestItemIds
	    Set<String> uniqueIds = new HashSet<>();
	    for (IssueItemDTO item : dto.getItems()) {
	    	if (item.getRequestItemId() == null
	    	        || item.getRequestItemId().isBlank()) {

	    	    throw new BadRequestException(
	    	            "Request item id is required");
	    	}
	        if (!uniqueIds.add(item.getRequestItemId())) {
	            throw new BadRequestException("Duplicate requestItemId");
	        }
	    }

	    // 🔒 3. Fetch Request
	    RequestResponseDTO request;

	    try {

	        request = requestClient
	                .getRequestById(dto.getRequestId());

	    } catch (FeignException.NotFound ex) {

	        throw new ResourceNotFoundException(
	                "Request not found");

	    } catch (FeignException.ServiceUnavailable ex) {

	        throw new ServiceUnavailableException(
	                "Request service unavailable");

	    } catch (FeignException ex) {

	        throw new ServiceUnavailableException(
	                "Request service communication failed");
	    }

	    if (request == null) {
	        throw new ResourceNotFoundException("Request not found");
	    }

	    if (request.getStatus() != RequestStatus.APPROVED &&
	    	    request.getStatus() != RequestStatus.PARTIALLY_APPROVED) {

	    	    throw new BadRequestException("Request is not approved for issuing");
	    	}
	    
	    if (request.getItems() == null
	            || request.getItems().isEmpty()) {

	        throw new ConflictException(
	                "Request contains no items");
	    }

	    // 🔒 4. Map Request Items
	    Map<String, RequestItemResponseDTO> requestItemMap =
	            request.getItems()
	                    .stream()
	                    .collect(Collectors.toMap(
	                            RequestItemResponseDTO::getRequestItemId,
	                            item -> item
	                    ));

	    // 🔒 5. Validate items + prevent over-issuance
	    Map<String, Integer> totalIssuedMap = getTotalIssuedQuantities(request.getId());

	    for (IssueItemDTO item : dto.getItems()) {

	        if (item.getQuantity() <= 0) {
	            throw new BadRequestException("Quantity must be greater than 0");
	        }

	        RequestItemResponseDTO reqItem = requestItemMap.get(item.getRequestItemId());

	        if (reqItem == null) {
	            throw new BadRequestException("Invalid requestItemId");
	        }

	        int alreadyIssued = totalIssuedMap.getOrDefault(item.getRequestItemId(), 0);
	        int approvedQty = reqItem.getQuantityApproved();

	        if (alreadyIssued + item.getQuantity() > approvedQty) {
	            throw new ConflictException(
	                    "Issuing exceeds approved limit for component");
	        }
	    }

	    // 🔒 6. Prepare Inventory Deduction
	    List<DeductRequestDTO> deductList = dto.getItems()
	            .stream()
	            .map(item -> {
	                RequestItemResponseDTO reqItem = requestItemMap.get(item.getRequestItemId());
	                return new DeductRequestDTO(reqItem.getComponentId(), item.getQuantity());
	            })
	            .toList();

	    BulkDeductRequestDTO bulkRequest = new BulkDeductRequestDTO();
	    bulkRequest.setItems(deductList);

	    // 🔥 7. Call Inventory Service
	    try {

	        inventoryClient.deductStock(bulkRequest);

	    } catch (FeignException.Conflict ex) {

	        throw new ConflictException(
	                "Insufficient stock available");

	    } catch (FeignException.ServiceUnavailable ex) {

	        throw new ServiceUnavailableException(
	                "Inventory service unavailable");

	    } catch (FeignException.InternalServerError ex) {

	        throw new ServiceUnavailableException(
	                "Inventory service error");

	    } catch (FeignException ex) {

	        throw new ServiceUnavailableException(
	                "Inventory service communication failed");
	    }

	    // 🔒 8. Create Issue
	    Issue issue = Issue.builder()
	            .requestId(dto.getRequestId())
	            .issuedBy(currentUser.getId())
	            .issueDate(LocalDateTime.now())
	            .build();

	    boolean allFullyIssued = true;

	    for (IssueItemDTO item : dto.getItems()) {

	        RequestItemResponseDTO reqItem = requestItemMap.get(item.getRequestItemId());
	        
	        IssueItem issueItem = IssueItem.builder()
	        		.requestItemId(item.getRequestItemId())
	        		.componentId(reqItem.getComponentId())
	        		.quantityIssued(item.getQuantity()).build();

	        issue.addItem(issueItem);

	        int alreadyIssued = totalIssuedMap.getOrDefault(item.getRequestItemId(), 0);

	        if (alreadyIssued + item.getQuantity() < reqItem.getQuantityApproved()) {
	            allFullyIssued = false;
	        }
	    }

	    // 🔒 9. Set status
	    issue.setStatus(allFullyIssued ? IssueStatus.ISSUED : IssueStatus.PARTIALLY_ISSUED);

	    // 🔒 10. Save
	    Issue savedIssue = issueRepository.save(issue);

	    return mapToResponseDTO(savedIssue);
	}

	@Override
	public IssueResponseDTO getIssueById(
	        String issueId,
	        CurrentUser currentUser) {

	    validateActiveUser(currentUser);

	    Issue issue = issueRepository.findById(issueId)
	            .orElseThrow(() ->
	                    new ResourceNotFoundException(
	                            "Issue not found"));

	    // 🔒 Access control
	    if (!canViewAllIssues(currentUser)
	            && !canAccessIssue(issue, currentUser)) {

	        throw new UnauthorizedException(
	                "Access denied");
	    }

	    return mapToResponseDTO(issue);
	}
	
	@Override
	public List<IssueResponseDTO> getIssuesByRequestId(
	        String requestId,
	        CurrentUser currentUser) {

	    validateActiveUser(currentUser);

	    List<Issue> issues =
	            issueRepository.findByRequestId(requestId);

	    if (issues.isEmpty()) {
	        return List.of();
	    }

	    // 🔒 Access control
	    if (!canViewAllIssues(currentUser)) {

	        boolean allowed = issues.stream()
	                .anyMatch(issue ->
	                        canAccessIssue(
	                                issue,
	                                currentUser
	                        )
	                );

	        if (!allowed) {
	            throw new UnauthorizedException(
	                    "Access denied");
	        }
	    }

	    return issues.stream()
	            .map(this::mapToResponseDTO)
	            .toList();
	}

	@Override
	public List<IssueResponseDTO> getAllIssues(
	        CurrentUser currentUser) {

	    validateActiveUser(currentUser);

	    if (!canViewAllIssues(currentUser)) {

	        throw new UnauthorizedException(
	                "Access denied");
	    }

	    return issueRepository.findAll()
	            .stream()
	            .map(this::mapToResponseDTO)
	            .toList();
	}
	
	// ========== HELPER ==========
	private IssueResponseDTO mapToResponseDTO(Issue issue) {

	    IssueResponseDTO dto = new IssueResponseDTO();

	    dto.setIssueId(issue.getId());
	    dto.setRequestId(issue.getRequestId());
	    dto.setIssuedBy(issue.getIssuedBy());
	    dto.setStatus(issue.getStatus().name());
	    dto.setIssueDate(issue.getIssueDate());

	    List<IssueItemResponseDTO> items = issue.getItems()
	            .stream()
	            .map(item -> {
	                IssueItemResponseDTO itemDTO = new IssueItemResponseDTO();
	                itemDTO.setIssueItemId(item.getId());
	                itemDTO.setComponentId(item.getComponentId());
	                itemDTO.setQuantityIssued(item.getQuantityIssued());
	                return itemDTO;
	            })
	            .toList();

	    dto.setItems(items);

	    return dto;
	}
	
	private Map<String, Integer> getTotalIssuedQuantities(String requestId) {

	    List<Issue> issues = issueRepository.findByRequestId(requestId);

	    return issues.stream()
	            .flatMap(issue -> issue.getItems().stream())
	            .collect(Collectors.groupingBy(
	                    IssueItem::getRequestItemId,
	                    Collectors.summingInt(IssueItem::getQuantityIssued)
	            ));
	}
	
	
	private void validateActiveUser(
	        CurrentUser currentUser) {

	    if (currentUser.getStatus() != Status.ACTIVE) {

	        throw new UnauthorizedException(
	                "Inactive users cannot access issues");
	    }
	}
	
	private void validateInstructor(CurrentUser currentUser) {

	    validateActiveUser(currentUser);

	    if (currentUser.getRole() != Role.INSTRUCTOR) {
	        throw new UnauthorizedException(
	                "Only instructors can issue components");
	    }
	}
	
	private boolean canViewAllIssues(
	        CurrentUser currentUser) {

	    return currentUser.getRole() == Role.ADMIN
	            || currentUser.getRole() == Role.INSTRUCTOR;
	}
	
	private boolean canAccessIssue(
	        Issue issue,
	        CurrentUser currentUser) {

	    try {

	        RequestResponseDTO request =
	                requestClient.getRequestById(
	                        issue.getRequestId());

	        return request.getCreatedBy()
	                .equals(currentUser.getId());

	    } catch (Exception ex) {

	        throw new ServiceUnavailableException(
	                "Request service unavailable");
	    }
	}
	
}
