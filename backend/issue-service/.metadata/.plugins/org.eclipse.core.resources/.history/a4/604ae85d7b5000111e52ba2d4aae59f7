package com.issue_service.controller;

import java.util.List;

import org.springframework.http.ResponseEntity;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.security.core.Authentication;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.issue_service.dto.request.CreateIssueDTO;
import com.issue_service.dto.response.IssueResponseDTO;
import com.issue_service.service.IssueService;

import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.responses.ApiResponse;
import io.swagger.v3.oas.annotations.responses.ApiResponses;
import io.swagger.v3.oas.annotations.tags.Tag;
import jakarta.validation.Valid;
import lombok.RequiredArgsConstructor;

@RestController
@RequestMapping("/issues")
@RequiredArgsConstructor
@Tag(name = "Issue Controller", description = "APIs for issuing components based on approved requests")
public class IssueController {

    private final IssueService issueService;

    // 🔥 1. CREATE ISSUE
    @Operation(summary = "Issue components for an approved request (Instructor only)")
    @ApiResponses({
        @ApiResponse(responseCode = "200", description = "Components issued successfully"),
        @ApiResponse(responseCode = "400", description = "Invalid issue request"),
        @ApiResponse(responseCode = "403", description = "Access denied"),
        @ApiResponse(responseCode = "404", description = "Request or component not found"),
        @ApiResponse(responseCode = "409", description = "Request already issued or invalid state"),
        @ApiResponse(responseCode = "422", description = "Insufficient stock")
    })
    @PreAuthorize("hasRole('INSTRUCTOR')")
    @PostMapping
    public ResponseEntity<IssueResponseDTO> issueComponents(
            @Valid @RequestBody CreateIssueDTO dto,
            Authentication authentication
    ) {
        return ResponseEntity.ok(
                issueService.issueComponents(dto, authentication.getName())
        );
    }

    // 🔍 2. GET ISSUE BY ID
    @Operation(summary = "Get issue details by ID")
    @ApiResponses({
        @ApiResponse(responseCode = "200", description = "Issue found"),
        @ApiResponse(responseCode = "403", description = "Access denied"),
        @ApiResponse(responseCode = "404", description = "Issue not found")
    })
    @PreAuthorize("hasAnyRole('ADMIN','INSTRUCTOR','STUDENT')")
    @GetMapping("/{id}")
    public ResponseEntity<IssueResponseDTO> getIssueById(
            @PathVariable String id,
            Authentication authentication
    ) {
        return ResponseEntity.ok(
                issueService.getIssueById(id, authentication.getName())
        );
    }

    // 🔍 3. GET ISSUES BY REQUEST ID
    @Operation(summary = "Get all issues linked to a request")
    @ApiResponses({
        @ApiResponse(responseCode = "200", description = "Issues fetched successfully"),
        @ApiResponse(responseCode = "403", description = "Access denied"),
        @ApiResponse(responseCode = "404", description = "Request not found")
    })
    @PreAuthorize("hasAnyRole('ADMIN','INSTRUCTOR','STUDENT')")
    @GetMapping("/request/{requestId}")
    public ResponseEntity<List<IssueResponseDTO>> getIssuesByRequestId(
            @PathVariable String requestId,
            Authentication authentication
    ) {
        return ResponseEntity.ok(
                issueService.getIssuesByRequestId(requestId, authentication.getName())
        );
    }

    // 🔍 4. GET ALL ISSUES
    @Operation(summary = "Get all issued components (Admin & Instructor only)")
    @ApiResponses({
        @ApiResponse(responseCode = "200", description = "Issues fetched successfully"),
        @ApiResponse(responseCode = "403", description = "Access denied")
    })
    @PreAuthorize("hasAnyRole('ADMIN','INSTRUCTOR')")
    @GetMapping
    public ResponseEntity<List<IssueResponseDTO>> getAllIssues(
            Authentication authentication
    ) {
        return ResponseEntity.ok(
                issueService.getAllIssues(authentication.getName())
        );
    }
}