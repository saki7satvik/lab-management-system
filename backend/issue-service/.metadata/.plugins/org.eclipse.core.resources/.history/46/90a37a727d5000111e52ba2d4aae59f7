//	}
	
	private void validateActiveUser(CurrentUser currentUser) {

	    if (currentUser.getStatus() != Status.ACTIVE) {
	        throw new UnauthorizedException(
	                "Inactive users cannot access issues");
	    }
	}
	
	private void validateInstructor(CurrentUser currentUser) {

	    validateActiveUser(currentUser);

	    if (currentUser.getRole() != Role.INSTRUCTOR) {
	        throw new UnauthorizedException(
	                "Only instructors can issue components");
	    }
	}
	
	private boolean canViewAllIssues(CurrentUser currentUser) {

	    return currentUser.getRole() == Role.ADMIN
	            || currentUser.getRole() == Role.INSTRUCTOR;
	}
	
	private boolean canAccessIssue(
	        Issue issue,
	        CurrentUser currentUser) {

	    RequestResponseDTO request =
	            requestClient.getRequestById(
	                    issue.getRequestId());

	    return request.getCreatedBy()
	            .equals(currentUser.getId());
	}
	
}
