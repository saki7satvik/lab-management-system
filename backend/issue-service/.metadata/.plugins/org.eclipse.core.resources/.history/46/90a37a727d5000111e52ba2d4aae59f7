import jakarta.transaction.Transactional;
import lombok.RequiredArgsConstructor;

@RequiredArgsConstructor
@Service
public class IssueServiceImpl implements IssueService {
	
	private final IssueRepository issueRepository;
	
	private final InventoryClient inventoryClient;
	
	private final RequestClient requestClient;
	
	@Override
	@Transactional
	public IssueResponseDTO issueComponents(CreateIssueDTO dto, CurrentUser currentUser) {

	    // 🔒 1. Validate input
	    if (dto.getItems() == null || dto.getItems().isEmpty()) {
	        throw new BadRequestException("Issue items cannot be empty");
	    }

	    // 🔒 2. Prevent duplicate requestItemIds
	    Set<String> uniqueIds = new HashSet<>();
	    for (IssueItemDTO item : dto.getItems()) {
	        if (!uniqueIds.add(item.getRequestItemId())) {
	            throw new BadRequestException("Duplicate requestItemId: " + item.getRequestItemId());
	        }
	    }

	    // 🔒 3. Fetch Request
	    RequestResponseDTO request = requestClient.getRequestById(dto.getRequestId());

	    if (request == null) {
	        throw new ResourceNotFoundException("Request not found");
	    }

	    if (request.getStatus() != RequestStatus.APPROVED &&
	    	    request.getStatus() != RequestStatus.PARTIALLY_APPROVED) {

	    	    throw new BadRequestException("Request is not approved for issuing");
	    	}

	    // 🔒 4. Map Request Items
	    Map<String, RequestItemResponseDTO> requestItemMap =
	            request.getItems()
	                    .stream()
	                    .collect(Collectors.toMap(
	                            RequestItemResponseDTO::getRequestItemId,
	                            item -> item
	                    ));

	    // 🔒 5. Validate items + prevent over-issuance
	    Map<String, Integer> totalIssuedMap = getTotalIssuedQuantities(request.getId());

	    for (IssueItemDTO item : dto.getItems()) {

	        if (item.getQuantity() <= 0) {
	            throw new BadRequestException("Quantity must be greater than 0");
	        }

	        RequestItemResponseDTO reqItem = requestItemMap.get(item.getRequestItemId());

	        if (reqItem == null) {
	            throw new BadRequestException("Invalid requestItemId: " + item.getRequestItemId());
	        }

	        int alreadyIssued = totalIssuedMap.getOrDefault(item.getRequestItemId(), 0);
	        int approvedQty = reqItem.getQuantityApproved();

	        if (alreadyIssued + item.getQuantity() > approvedQty) {
	            throw new ConflictException(
	                    "Issuing exceeds approved limit for component: " + reqItem.getComponentId()
	            );
	        }
	    }

	    // 🔒 6. Prepare Inventory Deduction
	    List<DeductRequestDTO> deductList = dto.getItems()
	            .stream()
	            .map(item -> {
	                RequestItemResponseDTO reqItem = requestItemMap.get(item.getRequestItemId());
	                return new DeductRequestDTO(reqItem.getComponentId(), item.getQuantity());
	            })
	            .toList();

	    BulkDeductRequestDTO bulkRequest = new BulkDeductRequestDTO();
	    bulkRequest.setItems(deductList);

	    // 🔥 7. Call Inventory Service
	    try {
	        inventoryClient.deductStock(bulkRequest);
	    } catch (Exception e) {
	        throw new ConflictException("Inventory service unavailable or stock insufficient");
	    }

	    // 🔒 8. Create Issue
	    Issue issue = Issue.builder()
	            .requestId(dto.getRequestId())
	            .issuedBy(instructorId)
	            .issueDate(LocalDateTime.now())
	            .build();

	    boolean allFullyIssued = true;

	    for (IssueItemDTO item : dto.getItems()) {

	        RequestItemResponseDTO reqItem = requestItemMap.get(item.getRequestItemId());

	        IssueItem issueItem = new IssueItem();
	        issueItem.setRequestItemId(item.getRequestItemId());
	        issueItem.setComponentId(reqItem.getComponentId());
	        issueItem.setQuantityIssued(item.getQuantity());

	        issue.addItem(issueItem);

	        int alreadyIssued = totalIssuedMap.getOrDefault(item.getRequestItemId(), 0);

	        if (alreadyIssued + item.getQuantity() < reqItem.getQuantityApproved()) {
	            allFullyIssued = false;
	        }
	    }

	    // 🔒 9. Set status
	    issue.setStatus(allFullyIssued ? IssueStatus.ISSUED : IssueStatus.PARTIALLY_ISSUED);

	    // 🔒 10. Save
	    Issue savedIssue = issueRepository.save(issue);

	    return mapToResponseDTO(savedIssue);
	}

	@Override
	public IssueResponseDTO getIssueById(String issueId, CurrentUser currentUser) {

	    Issue issue = issueRepository.findById(issueId)
	            .orElseThrow(() -> new ResourceNotFoundException("Issue not found"));

	    // 🔒 Access control
	    if (!isPrivilegedUser()) {

	        // Only allow owner (issuedTo) OR requester (via requestId check later)
	        if (!canAccessIssue(issue, currentUserId)) {
	            throw new UnauthorizedException("Access denied");
	        }
	    }

	    return mapToResponseDTO(issue);
	}
	
	@Override
	public List<IssueResponseDTO> getIssuesByRequestId(String requestId, CurrentUser currentUser) {

	    List<Issue> issues = issueRepository.findByRequestId(requestId);

	    if (issues.isEmpty()) {
	        return List.of();
	    }

	    // 🔒 Access control
	    if (!isPrivilegedUser()) {

	        boolean allowed = issues.stream()
	                .anyMatch(issue -> canAccessIssue(issue, currentUserId));

	        if (!allowed) {
	            throw new UnauthorizedException("Access denied");
	        }
	    }

	    return issues.stream()
	            .map(this::mapToResponseDTO)
	            .toList();
	}

	@Override
	public List<IssueResponseDTO> getAllIssues(CurrentUser currentUser) {

	    if (!isPrivilegedUser()) {
	        throw new UnauthorizedException("Access denied");
	    }
	    System.out.println("Access Approved");

	    return issueRepository.findAll()
	            .stream()
	            .map(this::mapToResponseDTO)
	            .toList();
	}
	
	// ========== HELPER ==========
	private IssueResponseDTO mapToResponseDTO(Issue issue) {

	    IssueResponseDTO dto = new IssueResponseDTO();

	    dto.setIssueId(issue.getId());
	    dto.setRequestId(issue.getRequestId());
	    dto.setIssuedBy(issue.getIssuedBy());
	    dto.setStatus(issue.getStatus().name());
	    dto.setIssueDate(issue.getIssueDate());

	    List<IssueItemResponseDTO> items = issue.getItems()
	            .stream()
	            .map(item -> {
	                IssueItemResponseDTO itemDTO = new IssueItemResponseDTO();
	                itemDTO.setIssueItemId(item.getId());
	                itemDTO.setComponentId(item.getComponentId());
	                itemDTO.setQuantityIssued(item.getQuantityIssued());
	                return itemDTO;
	            })
	            .toList();

	    dto.setItems(items);

	    return dto;
	}
	
	private Map<String, Integer> getTotalIssuedQuantities(String requestId) {

	    List<Issue> issues = issueRepository.findByRequestId(requestId);

	    return issues.stream()
	            .flatMap(issue -> issue.getItems().stream())
	            .collect(Collectors.groupingBy(
	                    IssueItem::getRequestItemId,
	                    Collectors.summingInt(IssueItem::getQuantityIssued)
	            ));
	}
	
	private boolean isPrivilegedUser() {
		System.out.println("Authenticating");
	    Authentication auth = SecurityContextHolder.getContext().getAuthentication();
	    System.out.println(auth.getName() + " | " + auth.getAuthorities());
	    return auth.getAuthorities().stream()
	            .anyMatch(a ->
	                    a.getAuthority().equals("ROLE_ADMIN") ||
	                    a.getAuthority().equals("ROLE_INSTRUCTOR")
	            );
	}
	
