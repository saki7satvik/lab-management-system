package com.issue_service.service;

import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyList;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import com.issue_service.dto.request.CreateIssueDTO;
import com.issue_service.dto.response.CurrentUser;
import com.issue_service.dto.response.RequestItemResponseDTO;
import com.issue_service.dto.response.RequestResponseDTO;
import com.issue_service.enums.RequestStatus;
import com.issue_service.enums.Role;
import com.issue_service.enums.Status;
import com.issue_service.repository.IssueRepository;
import com.issue_service.service.impl.IssueServiceImpl;

@ExtendWith(MockitoExtension.class)
public class IssueComponentServiceTests {
	@Mock
	private InventoryClient inventoryClient;
	
	@Mock
	private RequestClient requestClient;
	
	@Mock
	private IssueRepository issueRepository;
	
	@InjectMocks
	private IssueServiceImpl issueService;
	
	private CurrentUser instructorUser;
	private CurrentUser studentUser;
	private CurrentUser inactiveInstructor;
	
	private RequestItemResponseDTO requestItem1;
	private RequestItemResponseDTO requestItem2;

	private RequestResponseDTO requestResponse;
	
	@BeforeEach
	void setUp() {

	    instructorUser = CurrentUser.builder()
	            .id("INS_001")
	            .role(Role.INSTRUCTOR)
	            .status(Status.ACTIVE)
	            .build();

	    inactiveInstructor = CurrentUser.builder()
	            .id("INS_002")
	            .role(Role.INSTRUCTOR)
	            .status(Status.INACTIVE)
	            .build();

	    studentUser = CurrentUser.builder()
	            .id("STU_001")
	            .role(Role.STUDENT)
	            .status(Status.ACTIVE)
	            .build();

	    requestItem1 = RequestItemResponseDTO.builder()
	            .requestItemId("REQ_ITEM_1")
	            .componentId("COMP_1")
	            .quantityApproved(5)
	            .build();

	    requestItem2 = RequestItemResponseDTO.builder()
	            .requestItemId("REQ_ITEM_2")
	            .componentId("COMP_2")
	            .quantityApproved(3)
	            .build();

	    requestResponse = RequestResponseDTO.builder()
	            .id("REQ_001")
	            .createdBy("STU_001")
	            .status(RequestStatus.APPROVED)
	            .items(List.of(requestItem1, requestItem2))
	            .build();
	}
	
	@Test
	void issueComponents_success_fullIssue() {

	    CreateIssueDTO dto = CreateIssueDTO.builder()
	            .requestId("REQ_001")
	            .items(List.of(
	                    new IssueItemDTO(
	                            "REQ_ITEM_1",
	                            5
	                    )
	            ))
	            .build();

	    when(requestClient.getRequestById("REQ_001"))
	            .thenReturn(requestResponse);

	    when(issueRepository.getTotalIssuedQuantity("REQ_ITEM_1"))
	            .thenReturn(0);

	    when(issueRepository.save(any(Issue.class)))
	            .thenAnswer(inv -> inv.getArgument(0));

	    IssueResponseDTO response =
	            issueService.issueComponents(
	                    dto,
	                    instructorUser
	            );

	    assertNotNull(response);

	    verify(inventoryClient)
	            .deductStock(any());

	    verify(issueRepository)
	            .save(any(Issue.class));
	}
}
