	@Test
	void issueComponents_inventoryConflict() {

	    CreateIssueDTO dto = CreateIssueDTO.builder()
	            .requestId("REQ_001")
	            .items(List.of(
	                    new IssueItemDTO(
	                            "REQ_ITEM_1",
	                            1
	                    )
	            ))
	            .build();

	    when(requestClient.getRequestById("REQ_001"))
	            .thenReturn(requestResponse);

	    when(issueRepository.getTotalIssuedQuantity("REQ_ITEM_1"))
	            .thenReturn(0);

	    doThrow(mock(FeignException.Conflict.class))
	            .when(inventoryClient)
	            .deductStock(any());

	    assertThrows(
