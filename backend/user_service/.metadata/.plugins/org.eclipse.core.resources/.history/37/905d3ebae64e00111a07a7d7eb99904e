package com.user_service.controller;

import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.argThat;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;
import static org.springframework.security.test.web.servlet.request.SecurityMockMvcRequestPostProcessors.csrf;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.post;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.put;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.jsonPath;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.status;

import java.util.List;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.http.MediaType;
import org.springframework.security.test.context.support.WithMockUser;
import org.springframework.test.web.servlet.MockMvc;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.user_service.dto.CreateUserDTO;
import com.user_service.dto.UserResponseDTO;
import com.user_service.enums.Role;
import com.user_service.enums.Status;
import com.user_service.exception.ConflictException;
import com.user_service.exception.ResourceNotFoundException;
import com.user_service.exception.UnauthorizedException;
import com.user_service.service.UserService;

@WebMvcTest(UserController.class)
class UserControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @Autowired
    private ObjectMapper objectMapper;

    @MockBean
    private UserService userService;

    // =====================================================
    // 🧱 TEST DATA FACTORY
    // =====================================================

    static class TestDataFactory {

        static CreateUserDTO createUserDTO() {
            CreateUserDTO dto = new CreateUserDTO();

            dto.setCollegeId("STU_101");
            dto.setName("Satvik");
            dto.setEmail("satvik@test.com");
            dto.setPhone("9876543210");
            dto.setRole(Role.STUDENT);

            return dto;
        }

        static UserResponseDTO userResponseDTO(Status status) {

            return new UserResponseDTO(
                    "STU_101",
                    "Satvik",
                    "satvik@test.com",
                    "9876543210",
                    Role.STUDENT,
                    status
            );
        }
    }

    // =====================================================
    // 🔥 CREATE USER TESTS
    // =====================================================

    @Nested
    class CreateUserTests {

        @Test
        @DisplayName("ADMIN should create user successfully")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void createUser_success() throws Exception {

            CreateUserDTO dto = TestDataFactory.createUserDTO();

            when(userService.createUser(any(), any()))
                    .thenReturn(TestDataFactory.userResponseDTO(Status.ACTIVE));

            mockMvc.perform(post("/users")
                            .with(csrf())
                            .contentType(MediaType.APPLICATION_JSON)
                            .content(objectMapper.writeValueAsString(dto)))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.collegeId").value("STU_101"))
                    .andExpect(jsonPath("$.role").value("STUDENT"))
                    .andExpect(jsonPath("$.status").value("ACTIVE"));

            verify(userService).createUser(
                    argThat(user ->
                            user.getCollegeId().equals("STU_101")
                    ),
                    eq("ADMIN_001")
            );
        }

        @Test
        @DisplayName("Should return 401 for unauthenticated request")
        void createUser_unauthorized() throws Exception {

            mockMvc.perform(post("/users")
                            .with(csrf())
                            .contentType(MediaType.APPLICATION_JSON)
                            .content(objectMapper.writeValueAsString(
                                    TestDataFactory.createUserDTO()
                            )))
                    .andExpect(status().isUnauthorized());

            verify(userService, never()).createUser(any(), any());
        }

        @Test
        @DisplayName("STUDENT should not create user")
        @WithMockUser(username = "STU_001", roles = "STUDENT")
        void createUser_forbidden() throws Exception {

            mockMvc.perform(post("/users")
                            .with(csrf())
                            .contentType(MediaType.APPLICATION_JSON)
                            .content(objectMapper.writeValueAsString(
                                    TestDataFactory.createUserDTO()
                            )))
                    .andExpect(status().isForbidden());

            verify(userService, never()).createUser(any(), any());
        }

        @Test
        @DisplayName("Should return 400 for invalid DTO")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void createUser_invalidDTO() throws Exception {

            CreateUserDTO dto = new CreateUserDTO();

            mockMvc.perform(post("/users")
                            .with(csrf())
                            .contentType(MediaType.APPLICATION_JSON)
                            .content(objectMapper.writeValueAsString(dto)))
                    .andExpect(status().isBadRequest());

            verify(userService, never()).createUser(any(), any());
        }

        @Test
        @DisplayName("Should return 409 for duplicate user")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void createUser_duplicateUser() throws Exception {

            when(userService.createUser(any(), any()))
                    .thenThrow(new ConflictException("User already exists"));

            mockMvc.perform(post("/users")
                            .with(csrf())
                            .contentType(MediaType.APPLICATION_JSON)
                            .content(objectMapper.writeValueAsString(
                                    TestDataFactory.createUserDTO()
                            )))
                    .andExpect(status().isConflict());
        }
    }

    // =====================================================
    // 🔥 GET ALL USERS TESTS
    // =====================================================

    @Nested
    class GetAllUsersTests {

        @Test
        @DisplayName("Should fetch all users")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void getAllUsers_success() throws Exception {

            when(userService.getAllUsers(any()))
                    .thenReturn(List.of(
                            TestDataFactory.userResponseDTO(Status.ACTIVE)
                    ));

            mockMvc.perform(get("/users"))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$[0].collegeId")
                            .value("STU_101"));

            verify(userService).getAllUsers("ADMIN_001");
        }

        @Test
        @DisplayName("Should return 401 when unauthenticated")
        void getAllUsers_unauthorized() throws Exception {

            mockMvc.perform(get("/users"))
                    .andExpect(status().isUnauthorized());

            verify(userService, never()).getAllUsers(any());
        }
    }

    // =====================================================
    // 🔥 GET USER BY COLLEGE ID TESTS
    // =====================================================

    @Nested
    class GetUserByCollegeIdTests {

        @Test
        @DisplayName("Should fetch user by collegeId")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void getUserByCollegeId_success() throws Exception {

            when(userService.getUserByCollegeId(any(), any()))
                    .thenReturn(TestDataFactory.userResponseDTO(Status.ACTIVE));

            mockMvc.perform(get("/users/STU_101"))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.collegeId")
                            .value("STU_101"));

            verify(userService)
                    .getUserByCollegeId("STU_101", "ADMIN_001");
        }

        @Test
        @DisplayName("Should return 404 if user not found")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void getUserByCollegeId_notFound() throws Exception {

            when(userService.getUserByCollegeId(any(), any()))
                    .thenThrow(new ResourceNotFoundException("User not found"));

            mockMvc.perform(get("/users/STU_101"))
                    .andExpect(status().isNotFound());
        }

        @Test
        @DisplayName("Should return 403 if access denied")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void getUserByCollegeId_forbidden() throws Exception {

            when(userService.getUserByCollegeId(any(), any()))
                    .thenThrow(new UnauthorizedException("Access denied"));

            mockMvc.perform(get("/users/STU_101"))
                    .andExpect(status().isForbidden());
        }
    }

    // =====================================================
    // 🔥 DEACTIVATE USER TESTS
    // =====================================================

    @Nested
    class DeactivateUserTests {

        @Test
        @DisplayName("Should deactivate user successfully")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void deactivateUser_success() throws Exception {

            mockMvc.perform(put("/users/STU_101/deactivate")
                            .with(csrf()))
                    .andExpect(status().isOk());

            verify(userService)
                    .deactivateUser("STU_101", "ADMIN_001");
        }

        @Test
        @DisplayName("Should return 403 for STUDENT")
        @WithMockUser(username = "STU_001", roles = "STUDENT")
        void deactivateUser_forbidden() throws Exception {

            mockMvc.perform(put("/users/STU_101/deactivate")
                            .with(csrf()))
                    .andExpect(status().isForbidden());

            verify(userService, never())
                    .deactivateUser(any(), any());
        }

        @Test
        @DisplayName("Should return 404 if target user not found")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void deactivateUser_notFound() throws Exception {

            doThrow(new ResourceNotFoundException("User not found"))
                    .when(userService)
                    .deactivateUser(any(), any());

            mockMvc.perform(put("/users/STU_101/deactivate")
                            .with(csrf()))
                    .andExpect(status().isNotFound());
        }

        @Test
        @DisplayName("Should return 409 if already inactive")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void deactivateUser_conflict() throws Exception {

            doThrow(new ConflictException("Already inactive"))
                    .when(userService)
                    .deactivateUser(any(), any());

            mockMvc.perform(put("/users/STU_101/deactivate")
                            .with(csrf()))
                    .andExpect(status().isConflict());
        }
    }

    // =====================================================
    // 🔥 REACTIVATE USER TESTS
    // =====================================================

    @Nested
    class ReactivateUserTests {

        @Test
        @DisplayName("Should reactivate user successfully")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void reactivateUser_success() throws Exception {

            when(userService.reactivateUser(any(), any()))
                    .thenReturn(TestDataFactory.userResponseDTO(Status.ACTIVE));

            mockMvc.perform(put("/users/STU_101/reactivate")
                            .with(csrf()))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.status")
                            .value("ACTIVE"));

            verify(userService)
                    .reactivateUser("STU_101", "ADMIN_001");
        }

        @Test
        @DisplayName("Should return 403 for STUDENT")
        @WithMockUser(username = "STU_001", roles = "STUDENT")
        void reactivateUser_forbidden() throws Exception {

            mockMvc.perform(put("/users/STU_101/reactivate")
                            .with(csrf()))
                    .andExpect(status().isForbidden());

            verify(userService, never())
                    .reactivateUser(any(), any());
        }

        @Test
        @DisplayName("Should return 404 if user not found")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void reactivateUser_notFound() throws Exception {

            when(userService.reactivateUser(any(), any()))
                    .thenThrow(new ResourceNotFoundException("User not found"));

            mockMvc.perform(put("/users/STU_101/reactivate")
                            .with(csrf()))
                    .andExpect(status().isNotFound());
        }

        @Test
        @DisplayName("Should return 409 if already active")
        @WithMockUser(username = "ADMIN_001", roles = "ADMIN")
        void reactivateUser_conflict() throws Exception {

            when(userService.reactivateUser(any(), any()))
                    .thenThrow(new ConflictException("Already active"));

            mockMvc.perform(put("/users/STU_101/reactivate")
                            .with(csrf()))
                    .andExpect(status().isConflict());
        }
    }
}