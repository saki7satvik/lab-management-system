package com.user_service;

import static org.junit.jupiter.api.Assertions.assertDoesNotThrow;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import java.util.Optional;
import java.util.stream.Stream;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.junit.jupiter.params.ParameterizedTest;
import org.junit.jupiter.params.provider.Arguments;
import org.junit.jupiter.params.provider.EnumSource;
import org.junit.jupiter.params.provider.MethodSource;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.security.crypto.password.PasswordEncoder;

import com.user_service.dto.CreateUserDTO;
import com.user_service.dto.UserResponseDTO;
import com.user_service.entity.User;
import com.user_service.enums.Role;
import com.user_service.enums.Status;
import com.user_service.exception.ConflictException;
import com.user_service.exception.UnauthorizedException;
import com.user_service.repository.UserRepository;
import com.user_service.service.impl.UserServiceImpl;

@ExtendWith(MockitoExtension.class)
public class UserServiceTest {
	@Mock
	private UserRepository userRepository;
	
	@Mock
	private PasswordEncoder passwordEncoder;
	
	@InjectMocks
	private UserServiceImpl userService;
	
	// ========================================================
	// TEST DATA FACTORY
	// ========================================================
	static class TestDataFactory{
		
		static CreateUserDTO createUserDTO(Role role) {
			return new CreateUserDTO(
					"Test User",
					"SampleID_001",
					"test" + System.nanoTime() + "@mail.com",
					"9090909090",
					role
					);
		}
		
		static User creator(Role role, Status status) {
			User user = new User();
			user.setCollegeId("Creator_" + role);
			user.setRole(role);
			user.setStatus(status);
			return user;
		}
	}
	
	// =======================================================
	// USER TEST CASES
	// =======================================================
	@Nested
	@DisplayName("Create User Tests")
	class CreateUserTests{
		
		// SUCCESS CASE - WHAT HAPPENS WHEN THE USER IS SUCCESSFULLY CREATED
		@Test
		@DisplayName("Should create user when all the conditions are valid")
		void createUser_success() {
			User creator = TestDataFactory.creator(Role.ADMIN, Status.ACTIVE);
			CreateUserDTO dto = TestDataFactory.createUserDTO(Role.STUDENT);
			
			when(userRepository.findByCollegeId(creator.getCollegeId()))
	        .thenReturn(Optional.of(creator));
			
			when(userRepository.existsByCollegeId(dto.getCollegeId())).thenReturn(false);
			when(userRepository.existsByEmail(dto.getEmail())).thenReturn(false);
			when(passwordEncoder.encode(any())).thenReturn("encoded_password");
			when(userRepository.save(any(User.class)))
			.thenAnswer(invocation -> invocation.getArgument(0));
			
			UserResponseDTO response = userService.createUser(dto, creator.getCollegeId());
			
			assertNotNull(response);
			assertEquals(dto.getCollegeId(), response.getCollegeId());
			assertEquals(dto.getEmail(), response.getEmail());
			assertEquals(Role.STUDENT, response.getRole());
			
			verify(userRepository).existsByCollegeId(dto.getCollegeId());
			verify(userRepository).existsByEmail(dto.getEmail());
			verify(userRepository).save(any(User.class));
		}
		
		// CREATOR STATUS VALIDATION -> WHAT HAPPENS WHEN THE USER IS NOT ACTIVE
		@ParameterizedTest
		@EnumSource(Status.class)
		@DisplayName("Should allow only ACTIVE creator")
		void createUser_creatorStatus(Status status) {
			User creator = TestDataFactory.creator(Role.ADMIN, status);
			CreateUserDTO dto = TestDataFactory.createUserDTO(Role.STUDENT);
			
			if(status == Status.ACTIVE) {
				when(userRepository.existsByCollegeId(any())).thenReturn(false);
				when(userRepository.existsByEmail(any())).thenReturn(false);
				when(userRepository.save(any())).thenAnswer(i -> i.getArgument(0));
				
				assertDoesNotThrow(() -> userService.createUser(dto, creator.getCollegeId()));
			}
			else {
				assertThrows(UnauthorizedException.class, 
						() -> userService.createUser(dto, creator.getCollegeId()));
				verify(userRepository, never()).save(any());
			}
		}
		
		// ROLE HIERARCHY MATRIX
		@ParameterizedTest
        @MethodSource("roleMatrixProvider")
        @DisplayName("Should enforce role hierarchy rules")
		void createUser_roleMatrix(Role creatorRole, Role targetRole, boolean shouldPass) {
			
			User creator = TestDataFactory.creator(creatorRole, Status.ACTIVE);
            CreateUserDTO dto = TestDataFactory.createUserDTO(targetRole);

            when(userRepository.existsByCollegeId(any())).thenReturn(false);
            when(userRepository.existsByEmail(any())).thenReturn(false);
            
            if (shouldPass) {
                when(userRepository.save(any())).thenAnswer(i -> i.getArgument(0));

                assertDoesNotThrow(() -> userService.createUser(dto, creator.getCollegeId()));
                verify(userRepository).save(any());
            } else {
                assertThrows(UnauthorizedException.class,
                        () -> userService.createUser(dto, creator.getCollegeId()));

                verify(userRepository, never()).save(any());
            }
		}
		
		static Stream<Arguments> roleMatrixProvider() {
            return Stream.of(
                    Arguments.of(Role.SUPER_ADMIN, Role.ADMIN, true),
                    Arguments.of(Role.SUPER_ADMIN, Role.INSTRUCTOR, true),
                    Arguments.of(Role.ADMIN, Role.INSTRUCTOR, true),
                    Arguments.of(Role.ADMIN, Role.ADMIN, false),
                    Arguments.of(Role.INSTRUCTOR, Role.STUDENT, true),
                    Arguments.of(Role.INSTRUCTOR, Role.ADMIN, false),
                    Arguments.of(Role.STUDENT, Role.STUDENT, false)
            );
        }
		
        // DUPLICATE COLLEGE ID
        @Test
        @DisplayName("Should reject duplicate collegeId")
        void createUser_duplicateCollegeId() {

            User creator = TestDataFactory.creator(Role.ADMIN, Status.ACTIVE);
            CreateUserDTO dto = TestDataFactory.createUserDTO(Role.STUDENT);

            when(userRepository.existsByCollegeId(dto.getCollegeId())).thenReturn(true);

            assertThrows(ConflictException.class,
                    () -> userService.createUser(dto, creator.getCollegeId()));

            verify(userRepository, never()).save(any());
        }
        
        // DUPLICATE EMAIL
        @Test
        @DisplayName("Should reject duplicate email")
        void createUser_duplicateEmail() {

            User creator = TestDataFactory.creator(Role.ADMIN, Status.ACTIVE);
            CreateUserDTO dto = TestDataFactory.createUserDTO(Role.STUDENT);

            when(userRepository.existsByCollegeId(dto.getCollegeId())).thenReturn(false);
            when(userRepository.existsByEmail(dto.getEmail())).thenReturn(true);

            assertThrows(ConflictException.class,
                    () -> userService.createUser(dto, creator.getCollegeId()));

            verify(userRepository, never()).save(any());
        }
        
        // NULL INPUTS (EDGE CASES)
        @Test
        @DisplayName("Should fail when DTO is null")
        void createUser_nullDTO() {

            User creator = TestDataFactory.creator(Role.ADMIN, Status.ACTIVE);

            assertThrows(NullPointerException.class,
                    () -> userService.createUser(null, creator.getCollegeId()));
        }

        @Test
        @DisplayName("Should fail when creator is null")
        void createUser_nullCreator() {

            CreateUserDTO dto = TestDataFactory.createUserDTO(Role.STUDENT);

            assertThrows(NullPointerException.class,
                    () -> userService.createUser(dto, null));
        }
	}
}
