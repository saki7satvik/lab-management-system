package com.user_service.controller;

import java.util.List;

import org.springframework.http.ResponseEntity;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.security.core.Authentication;
import org.springframework.web.bind.annotation.*;

import com.user_service.dto.CreateUserDTO;
import com.user_service.dto.UserResponseDTO;
import com.user_service.service.UserService;

import jakarta.validation.Valid;

@RestController
@RequestMapping("/users")
public class UserController {

    private final UserService userService;

    public UserController(UserService userService) {
        this.userService = userService;
    }

    // 🔥 1. CREATE USER
    @PreAuthorize("hasRole('ADMIN')")
    @PostMapping
    public UserResponseDTO createUser(@RequestBody CreateUserDTO dto,
                                      Authentication authentication) {

        String currentUserCollegeId = authentication.getName();
        return userService.createUser(dto, currentUserCollegeId);
    }

    // 🔥 2. GET ALL USERS (ROLE FILTERED)
    @GetMapping
    public ResponseEntity<List<UserResponseDTO>> getAllUsers(
            @RequestHeader("collegeId") String currentUserCollegeId) {
    	System.out.println("college Id: " + currentUserCollegeId);
        return ResponseEntity.ok(
                userService.getAllUsers(currentUserCollegeId)
        );
    }

    // 🔥 3. GET USER BY COLLEGE ID
    @GetMapping("/{collegeId}")
    public ResponseEntity<UserResponseDTO> getUserByCollegeId(
            @PathVariable String collegeId,
            @RequestHeader("collegeId") String currentUserCollegeId) {
    	System.out.println("college Id: " + currentUserCollegeId);
        return ResponseEntity.ok(
                userService.getUserByCollegeId(collegeId, currentUserCollegeId)
        );
    }

    // 🔥 4. DEACTIVATE USER
    @PreAuthorize("hasAnyRole('ADMIN', 'SUPER_ADMIN')")
    @PutMapping("/{collegeId}/deactivate")
    public ResponseEntity<UserResponseDTO> deactivateUser(
            @PathVariable String collegeId,
            @RequestHeader("collegeId") String currentUserCollegeId) {
    	System.out.println("college Id: " + currentUserCollegeId);
        return ResponseEntity.ok(
                userService.deactivateUser(collegeId, currentUserCollegeId)
        );
    }
    
    // 5. REACTIVATE USER
    @PreAuthorize("hasAnyRole('ADMIN', 'SUPER_ADMIN')")
    @PutMapping("/{collegeId}/reactivate")
    public ResponseEntity<UserResponseDTO> reactivateUser(
            @PathVariable String collegeId,
            @RequestHeader("collegeId") String currentUserCollegeId) {
    	System.out.println("college Id: " + currentUserCollegeId);
        return ResponseEntity.ok(
                userService.reactivateUser(collegeId, currentUserCollegeId)
        );
    }
}