package com.user_service.controller;

import static org.mockito.Mockito.*;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.netflix.discovery.converters.Auto;
import com.user_service.dto.CreateUserDTO;
import com.user_service.dto.UserResponseDTO;
import com.user_service.enums.Role;
import com.user_service.enums.Status;
import com.user_service.service.UserService;

import org.junit.jupiter.api.Test;
import org.mockito.Mock;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.http.MediaType;
import org.springframework.security.test.context.support.WithMockUser;
import org.springframework.test.web.servlet.MockMvc;

@WebMvcTest(UserController.class)
class UserControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @Autowired
    private UserService userService;

    @Autowired
    private ObjectMapper objectMapper;

    // -----------------------------------------------------
    // 🧱 TEST DATA
    // -----------------------------------------------------

    private CreateUserDTO validCreateDTO() {
        CreateUserDTO dto = new CreateUserDTO();
        dto.setCollegeId("STU_101");
        dto.setName("Satvik");
        dto.setEmail("satvik@test.com");
        dto.setPhone("1234567890");
        dto.setRole(Role.STUDENT);
        return dto;
    }

    private UserResponseDTO responseDTO() {
        return new UserResponseDTO(
                "STU_101",
                "Satvik",
                "satvik@test.com",
                "1234567890",
                Role.STUDENT,
                Status.ACTIVE
        );
    }

    // =====================================================
    // 🟢 CREATE USER
    // =====================================================

    @Test
    @WithMockUser(roles = "ADMIN")
    void createUser_success() throws Exception {

        CreateUserDTO dto = validCreateDTO();

        when(userService.createUser(any(), any()))
                .thenReturn(responseDTO());

        mockMvc.perform(post("/users")
                        .header("collegeId", "ADMIN_001")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(dto)))
                .andExpect(status().isCreated())
                .andExpect(jsonPath("$.collegeId").value("STU_101"))
                .andExpect(jsonPath("$.role").value("STUDENT"));

        verify(userService).createUser(any(), any());
    }

    @Test
    @WithMockUser(roles = "ADMIN")
    void createUser_invalidDTO() throws Exception {

        CreateUserDTO dto = new CreateUserDTO(); // empty

        mockMvc.perform(post("/users")
                        .header("collegeId", "ADMIN_001")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(dto)))
                .andExpect(status().isBadRequest());

        verify(userService, never()).createUser(any(), any());
    }

    @Test
    @WithMockUser(roles = "STUDENT")
    void createUser_forbidden() throws Exception {

        mockMvc.perform(post("/users")
                        .header("collegeId", "STU_001")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(validCreateDTO())))
                .andExpect(status().isForbidden());

        verify(userService, never()).createUser(any(), any());
    }

    // =====================================================
    // 🔴 GET USERS
    // =====================================================

    @Test
    @WithMockUser(roles = "ADMIN")
    void getUsers_success() throws Exception {

        mockMvc.perform(get("/users")
                        .header("collegeId", "ADMIN_001"))
                .andExpect(status().isOk());

        verify(userService).getAllUsers(any());
    }

    @Test
    void getUsers_unauthorized() throws Exception {

        mockMvc.perform(get("/users"))
                .andExpect(status().isUnauthorized());
    }

    // =====================================================
    // 🔴 DEACTIVATE USER
    // =====================================================

    @Test
    @WithMockUser(roles = "ADMIN")
    void deactivateUser_success() throws Exception {

        when(userService.deactivateUser(any(), any()))
                .thenReturn(responseDTO());

        mockMvc.perform(put("/users/STU_101/deactivate")
                        .header("collegeId", "ADMIN_001"))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.status").value("ACTIVE")); // response before change mapping

        verify(userService).deactivateUser("STU_101", "ADMIN_001");
    }

    @Test
    @WithMockUser(roles = "STUDENT")
    void deactivateUser_forbidden() throws Exception {

        mockMvc.perform(put("/users/STU_101/deactivate")
                        .header("collegeId", "STU_001"))
                .andExpect(status().isForbidden());

        verify(userService, never()).deactivateUser(any(), any());
    }

    // =====================================================
    // 🟢 REACTIVATE USER
    // =====================================================

    @Test
    @WithMockUser(roles = "ADMIN")
    void reactivateUser_success() throws Exception {

        when(userService.reactivateUser(any(), any()))
                .thenReturn(responseDTO());

        mockMvc.perform(put("/users/STU_101/reactivate")
                        .header("collegeId", "ADMIN_001"))
                .andExpect(status().isOk());

        verify(userService).reactivateUser("STU_101", "ADMIN_001");
    }

    @Test
    @WithMockUser(roles = "STUDENT")
    void reactivateUser_forbidden() throws Exception {

        mockMvc.perform(put("/users/STU_101/reactivate")
                        .header("collegeId", "STU_001"))
                .andExpect(status().isForbidden());

        verify(userService, never()).reactivateUser(any(), any());
    }
}