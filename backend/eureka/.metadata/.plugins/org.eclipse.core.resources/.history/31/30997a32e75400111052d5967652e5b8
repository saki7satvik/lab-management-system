package com.return_service.service.impl;

import java.util.*;
import java.util.stream.Collectors;

import org.springframework.stereotype.Service;

import com.return_service.dto.*;
import com.return_service.dto.external.*;
import com.return_service.entity.Return;
import com.return_service.entity.ReturnItem;
import com.return_service.enums.ItemCondition;
import com.return_service.enums.RequestStatus;
import com.return_service.enums.ReturnStatus;
import com.return_service.enums.Role;
import com.return_service.enums.Status;
import com.return_service.exception.BadRequestException;
import com.return_service.exception.ConflictException;
import com.return_service.exception.ResourceNotFoundException;
import com.return_service.exception.ServiceUnavailableException;
import com.return_service.exception.UnauthorizedException;
import com.return_service.repository.ReturnRepository;
import com.return_service.service.InventoryClient;
import com.return_service.service.RequestClient;
import com.return_service.service.ReturnService;

import feign.FeignException;

import org.springframework.transaction.annotation.Transactional;
import lombok.AllArgsConstructor;

@Service
@AllArgsConstructor
public class ReturnServiceImpl implements ReturnService {
		
	private final RequestClient requestClient;
	
	private final InventoryClient inventoryClient;
	
	private final ReturnRepository returnRepository;
	
	@Override
	@Transactional
	public ReturnResponseDTO processReturn(ProcessReturnRequestDTO request, CurrentUser currentUser) {

	    validateInstructor(currentUser);

	    if (request.getItems() == null || request.getItems().isEmpty()) {
	        throw new BadRequestException("Return items cannot be empty");
	    }

	    // 1. Fetch Request
	    RequestResponseDTO requestData;

	    try {

	        requestData = requestClient.getAllRequests()
	                .stream()
	                .filter(r -> r.getId().equals(request.getRequestId()))
	                .findFirst()
	                .orElseThrow(() -> new ResourceNotFoundException("Request not found"));

	    } catch (FeignException ex) {

	        throw new ServiceUnavailableException(
	                "Request service unavailable");
	    }

	    // 2. Validate request status
	    if (requestData.getStatus() != RequestStatus.APPROVED
	            && requestData.getStatus() != RequestStatus.PARTIALLY_APPROVED) {

	        throw new BadRequestException(
	                "Invalid request status for return");
	    }

	    // 3. Map request items
	    Map<String, RequestItemResponseDTO> requestItemMap =
	            requestData.getItems()
	                    .stream()
	                    .collect(Collectors.toMap(
	                            RequestItemResponseDTO::getId,
	                            i -> i
	                    ));

	    // 4. Validate input + prevent duplicates
	    Set<String> seen = new HashSet<>();

	    for (ProcessReturnItemDTO item : request.getItems()) {

	        if (item.getRequestItemId() == null
	                || item.getRequestItemId().isBlank()) {

	            throw new BadRequestException(
	                    "Request item id is required");
	        }

	        if (!seen.add(item.getRequestItemId())) {

	            throw new BadRequestException(
	                    "Duplicate requestItemId");
	        }

	        RequestItemResponseDTO requestItem =
	                requestItemMap.get(item.getRequestItemId());

	        if (requestItem == null) {

	            throw new BadRequestException(
	                    "Invalid requestItemId");
	        }

	        if (item.getQuantityReturned() <= 0) {

	            throw new BadRequestException(
	                    "Quantity must be greater than 0");
	        }

	        // 🔥 prevent over-return
	        int alreadyReturned = returnRepository
	                .getTotalReturnedQuantity(
	                        item.getRequestItemId());

	        if (alreadyReturned + item.getQuantityReturned() > requestItem.getQuantityApproved()) {
	            throw new ConflictException(
	                String.format("Return exceeds approved quantity! Already returned: %d, Attempting: %d, Approved: %d", 
	                              alreadyReturned, item.getQuantityReturned(), requestItem.getQuantityApproved())
	            );
	        }
	    }

	    // 5. Create Return entity
	    Return returnEntity = Return.builder()
	            .requestId(requestData.getId())
	            .returnedBy(requestData.getCreatedBy())
	            .inspectedBy(currentUser.getId())
	            .status(ReturnStatus.COMPLETED)
	            .remarks(request.getRemarks())
	            .fineGenerated(false)
	            .build();

	    List<ReturnItem> returnItems = new ArrayList<>();

	    // 6. Prepare inventory add-back
	    Map<String, Integer> addBackMap = new HashMap<>();

	    boolean hasDamage = false;

	    for (ProcessReturnItemDTO itemDTO : request.getItems()) {

	        RequestItemResponseDTO requestItem =
	                requestItemMap.get(itemDTO.getRequestItemId());

	        ReturnItem returnItem = ReturnItem.builder()
	                .requestItemId(itemDTO.getRequestItemId())
	                .componentId(requestItem.getComponentId())
	                .quantityReturned(itemDTO.getQuantityReturned())
	                .condition(itemDTO.getCondition())
	                .damageRemarks(itemDTO.getDamageRemarks())
	                .processed(true)
	                .returnEntity(returnEntity)
	                .build();

	        returnItems.add(returnItem);

	        // 7. Inventory add-back
	        if (itemDTO.getCondition() == ItemCondition.GOOD) {

	            addBackMap.merge(
	                    requestItem.getComponentId(),
	                    itemDTO.getQuantityReturned(),
	                    Integer::sum
	            );

	        } else {

	            hasDamage = true;
	        }
	    }

	    returnEntity.setItems(returnItems);

	    // 8. Add stock back
	    if (!addBackMap.isEmpty()) {

	        List<AddBackRequestDTO> addBackList =
	                addBackMap.entrySet()
	                        .stream()
	                        .map(e -> new AddBackRequestDTO(
	                                e.getKey(),
	                                e.getValue()
	                        ))
	                        .toList();

	        BulkAddBackRequestDTO bulkRequest =
	                new BulkAddBackRequestDTO();

	        bulkRequest.setItems(addBackList);

	        try {

	            inventoryClient.addBackStock(bulkRequest);

	        } catch (FeignException ex) {

	            throw new ServiceUnavailableException(
	                    "Inventory service unavailable");
	        }
	    }

	    // 9. Fine placeholder
	    if (hasDamage) {

	        // TODO: Fine service integration
	        returnEntity.setFineGenerated(true);
	    }

	    // 10. Save
	    Return saved = returnRepository.save(returnEntity);

	    // 11. Response
	    return mapToResponse(saved);
	}
	
	@Override
	@Transactional(readOnly = true)
	public ReturnResponseDTO getReturnById(
	        String returnId,
	        CurrentUser currentUser
	) {

	    validateActiveUser(currentUser);

	    Return returnEntity = returnRepository.findById(returnId)
	            .orElseThrow(() ->
	                    new ResourceNotFoundException(
	                            "Return not found"));

	    // Student can only view their own returns
	    if (!canViewAllReturns(currentUser)
	            && !returnEntity.getReturnedBy()
	                    .equals(currentUser.getId())) {

	        throw new UnauthorizedException(
	                "Access denied");
	    }

	    return mapToResponse(returnEntity);
	}

	@Override
	@Transactional(readOnly = true)
	public List<ReturnResponseDTO> getReturns(
	        CurrentUser currentUser
	) {

	    validateActiveUser(currentUser);

	    List<Return> returns;

	    if (currentUser.getRole() == Role.STUDENT) {

	        // Student sees only own returns
	        returns = returnRepository.findByReturnedBy(
	                currentUser.getId());

	    } else {

	        // Instructor/Admin sees all returns
	        returns = returnRepository.findAll();
	    }

	    return returns.stream()
	            .map(this::mapToResponse)
	            .toList();
	}
	
	@Override
	@Transactional(readOnly = true)
	public List<ReturnResponseDTO> getReturnsByRequest(
	        String requestId,
	        CurrentUser currentUser
	) {

	    validateActiveUser(currentUser);

	    List<Return> returns =
	            returnRepository.findByRequestId(requestId);

	    // Student can only view their own returns
	    if (currentUser.getRole() == Role.STUDENT) {

	        boolean allowed = returns.stream()
	                .allMatch(r ->
	                        r.getReturnedBy()
	                                .equals(currentUser.getId()));

	        if (!allowed) {

	            throw new UnauthorizedException(
	                    "Access denied");
	        }
	    }

	    return returns.stream()
	            .map(this::mapToResponse)
	            .toList();
	}
	
	private ReturnResponseDTO mapToResponse(Return returnEntity) {

		List<ReturnItemResponseDTO> itemResponses =
	            returnEntity.getItems()
	                    .stream()
	                    .map(item -> ReturnItemResponseDTO.builder()
	                            .id(item.getId())
	                            .requestItemId(item.getRequestItemId())
	                            .componentId(item.getComponentId())
	                            .quantityReturned(item.getQuantityReturned())
	                            .condition(item.getCondition())
	                            .damageRemarks(item.getDamageRemarks())
	                            .processed(item.isProcessed())
	                            .build()
	                    )
	                    .toList();

	    return ReturnResponseDTO.builder()
	            .id(returnEntity.getId())
	            .requestId(returnEntity.getRequestId())
	            .returnedBy(returnEntity.getReturnedBy())
	            .inspectedBy(returnEntity.getInspectedBy())
	            .status(returnEntity.getStatus())
	            .overallCondition(returnEntity.getOverallCondition())
	            .fineGenerated(returnEntity.isFineGenerated())
	            .remarks(returnEntity.getRemarks())
	            .createdAt(returnEntity.getCreatedAt())
	            .inspectedAt(returnEntity.getInspectedAt())
	            .items(itemResponses)
	            .build();
	}
	
	private void validateActiveUser(CurrentUser currentUser) {

	    if (currentUser.getStatus() != Status.ACTIVE) {

	        throw new UnauthorizedException(
	                "Inactive users cannot access returns");
	    }
	}
	
	private void validateInstructor(CurrentUser currentUser) {

	    validateActiveUser(currentUser);

	    if (currentUser.getRole() != Role.INSTRUCTOR) {

	        throw new UnauthorizedException(
	                "Only instructors can process returns");
	    }
	}
	
	private boolean canViewAllReturns(CurrentUser currentUser) {

	    return currentUser.getRole() == Role.ADMIN
	            || currentUser.getRole() == Role.INSTRUCTOR;
	}



}
