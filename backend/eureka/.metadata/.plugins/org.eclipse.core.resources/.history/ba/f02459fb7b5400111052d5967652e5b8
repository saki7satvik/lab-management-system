package com.request_service.service;

import java.util.List;
import java.util.Map;

import org.springframework.cloud.openfeign.FeignClient;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;

import com.request_service.dto.external.BulkStockUpdateDTO;
import com.request_service.dto.external.StockUpdateResponseDTO;
import com.request_service.dto.request.BulkDeductStockRequestDTO;

@FeignClient(name = "INVENTORY-SERVICE")
public interface InventoryClient {

    @PostMapping("/components/validate")
    Map<String, Boolean> validateComponents(
        @RequestBody List<String> componentIds
    );

    @PostMapping("/components/availability")
    Map<String, Integer> getAvailableQuantities(
        @RequestBody List<String> componentIds
    );
    
    @PostMapping("/components/deduct")
	List<StockUpdateResponseDTO> deductStock(BulkStockUpdateDTO deductRequest);
}
