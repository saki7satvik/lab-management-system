package com.return_service.service;

import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.junit.jupiter.api.Assertions.assertTrue;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyList;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import java.util.List;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import com.return_service.dto.CurrentUser;
import com.return_service.dto.ProcessReturnItemDTO;
import com.return_service.dto.ProcessReturnRequestDTO;
import com.return_service.dto.ReturnResponseDTO;
import com.return_service.dto.external.IssueItemDTO;
import com.return_service.dto.external.IssueResponseDTO;
import com.return_service.entity.Return;
import com.return_service.enums.IssueStatus;
import com.return_service.enums.ItemCondition;
import com.return_service.enums.Role;
import com.return_service.enums.Status;
import com.return_service.exception.UnauthorizedException;
import com.return_service.repository.ReturnRepository;
import com.return_service.service.impl.ReturnServiceImpl;

@ExtendWith(MockitoExtension.class)
public class ProcessReturnTests {
	@Mock
	private ReturnRepository returnRepository;
	
	@Mock
	private InventoryClient inventoryClient;
	
	@Mock
	private IssueClient issueClient;
	
	@InjectMocks
	private ReturnServiceImpl returnService;
	
	private CurrentUser instructorUser;
	private CurrentUser studentUser;
	private CurrentUser inactiveInstructor;

	private IssueResponseDTO issue;
	private IssueItemDTO issueItem1;
	private IssueItemDTO issueItem2;
	
	@BeforeEach
	void setUp() {

	    instructorUser = CurrentUser.builder()
	            .id("INS_001")
	            .role(Role.INSTRUCTOR)
	            .status(Status.ACTIVE)
	            .build();

	    inactiveInstructor = CurrentUser.builder()
	            .id("INS_002")
	            .role(Role.INSTRUCTOR)
	            .status(Status.INACTIVE)
	            .build();

	    studentUser = CurrentUser.builder()
	            .id("STU_001")
	            .role(Role.STUDENT)
	            .status(Status.ACTIVE)
	            .build();

	    issueItem1 = IssueItemDTO.builder()
	            .issueItemId("ITEM_1")
	            .componentId("COMP_1")
	            .quantityIssued(5)
	            .build();

	    issueItem2 = IssueItemDTO.builder()
	            .issueItemId("ITEM_2")
	            .componentId("COMP_2")
	            .quantityIssued(3)
	            .build();

	    issue = IssueResponseDTO.builder()
	            .IssueId("ISSUE_1")
	            .issuedBy("STU_001")
	            .status(IssueStatus.ISSUED)
	            .items(List.of(issueItem1, issueItem2))
	            .build();
	}
	
	@Test
	void processReturn_success() {

	    ProcessReturnRequestDTO request =
	            ProcessReturnRequestDTO.builder()
	                    .issueId("ISSUE_1")
	                    .remarks("Returned")
	                    .items(List.of(
	                            ProcessReturnItemDTO.builder()
	                                    .issueItemId("ITEM_1")
	                                    .quantityReturned(2)
	                                    .condition(ItemCondition.GOOD)
	                                    .build()
	                    ))
	                    .build();

	    when(issueClient.getIssueById("ISSUE_1"))
	            .thenReturn(issue);

	    when(returnRepository.getTotalReturnedQuantity("ITEM_1"))
	            .thenReturn(0);

	    when(returnRepository.save(any(Return.class)))
	            .thenAnswer(inv -> inv.getArgument(0));

	    ReturnResponseDTO response =
	            returnService.processReturn(
	                    request,
	                    instructorUser
	            );

	    assertNotNull(response);

	    verify(inventoryClient)
	            .addBackStock(any());

	    verify(returnRepository)
	            .save(any(Return.class));
	}
	
	@Test
	void processReturn_damagedItem_generatesFine() {

	    ProcessReturnRequestDTO request =
	            ProcessReturnRequestDTO.builder()
	                    .issueId("ISSUE_1")
	                    .items(List.of(
	                            ProcessReturnItemDTO.builder()
	                                    .issueItemId("ITEM_1")
	                                    .quantityReturned(1)
	                                    .condition(ItemCondition.DAMAGED)
	                                    .damageRemarks("Broken")
	                                    .build()
	                    ))
	                    .build();

	    when(issueClient.getIssueById("ISSUE_1"))
	            .thenReturn(issue);

	    when(returnRepository.getTotalReturnedQuantity("ITEM_1"))
	            .thenReturn(0);

	    when(returnRepository.save(any(Return.class)))
	            .thenAnswer(inv -> inv.getArgument(0));

	    returnService.processReturn(
	            request,
	            instructorUser
	    );

	    ArgumentCaptor<Return> captor =
	            ArgumentCaptor.forClass(Return.class);

	    verify(returnRepository).save(captor.capture());

	    assertTrue(captor.getValue().isFineGenerated());

	    verify(inventoryClient, never())
	            .addBackStock(any());
	}
	
	@Test
	void processReturn_studentForbidden() {

	    ProcessReturnRequestDTO request =
	            ProcessReturnRequestDTO.builder()
	                    .issueId("ISSUE_1")
	                    .items(List.of(
	                            ProcessReturnItemDTO.builder()
	                                    .issueItemId("ITEM_1")
	                                    .quantityReturned(1)
	                                    .condition(ItemCondition.GOOD)
	                                    .build()
	                    ))
	                    .build();

	    assertThrows(
	            UnauthorizedException.class,
	            () -> returnService.processReturn(
	                    request,
	                    studentUser
	            )
	    );

	    verify(issueClient, never())
	            .getIssueById(any());
	}
	

}
