package com.return_service.service;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.junit.jupiter.api.Assertions.assertTrue;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;
import static org.mockito.Mockito.doThrow;
import static org.mockito.Mockito.mock;

import java.util.List;
import java.util.Optional;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import com.return_service.dto.CurrentUser;
import com.return_service.dto.ReturnResponseDTO;
import com.return_service.entity.Return;
import com.return_service.entity.ReturnItem;
import com.return_service.enums.ItemCondition;
import com.return_service.enums.ReturnStatus;
import com.return_service.enums.Role;
import com.return_service.enums.Status;
import com.return_service.exception.ResourceNotFoundException;
import com.return_service.exception.UnauthorizedException;
import com.return_service.repository.ReturnRepository;
import com.return_service.service.impl.ReturnServiceImpl;

@ExtendWith(MockitoExtension.class)
public class ReturnGetMethodTests {
	
	@Mock
	private ReturnRepository returnRepository;
	
	@Mock
	private InventoryClient inventoryClient;
	
	@Mock
	private IssueClient issueClient;
	
	@InjectMocks
	private ReturnServiceImpl returnService;
	
	private CurrentUser studentUser;
	private CurrentUser anotherStudent;
	private CurrentUser instructorUser;
	private CurrentUser adminUser;
	private CurrentUser inactiveStudent;

	private Return returnEntity;
	private ReturnItem returnItem;
	
	@BeforeEach
	void setUp() {

	    studentUser = CurrentUser.builder()
	            .id("STU_001")
	            .role(Role.STUDENT)
	            .status(Status.ACTIVE)
	            .build();

	    anotherStudent = CurrentUser.builder()
	            .id("STU_002")
	            .role(Role.STUDENT)
	            .status(Status.ACTIVE)
	            .build();

	    instructorUser = CurrentUser.builder()
	            .id("INS_001")
	            .role(Role.INSTRUCTOR)
	            .status(Status.ACTIVE)
	            .build();

	    adminUser = CurrentUser.builder()
	            .id("ADM_001")
	            .role(Role.ADMIN)
	            .status(Status.ACTIVE)
	            .build();

	    inactiveStudent = CurrentUser.builder()
	            .id("STU_003")
	            .role(Role.STUDENT)
	            .status(Status.INACTIVE)
	            .build();

	    returnItem = ReturnItem.builder()
	            .issueItemId("ITEM_1")
	            .quantityReturned(2)
	            .condition(ItemCondition.GOOD)
	            .processed(true)
	            .build();

	    returnEntity = Return.builder()
	            .id("RET_001")
	            .issueId("ISSUE_1")
	            .returnedBy("STU_001")
	            .inspectedBy("INS_001")
	            .status(ReturnStatus.COMPLETED)
	            .items(List.of(returnItem))
	            .build();
	}
	
	@Test
	void getReturnById_studentOwnReturn_success() {

	    when(returnRepository.findById("RET_001"))
	            .thenReturn(Optional.of(returnEntity));

	    ReturnResponseDTO response =
	            returnService.getReturnById(
	                    "RET_001",
	                    studentUser
	            );

	    assertNotNull(response);

	    verify(returnRepository)
	            .findById("RET_001");
	}
	
	@Test
	void getReturnById_instructorAccess_success() {

	    when(returnRepository.findById("RET_001"))
	            .thenReturn(Optional.of(returnEntity));

	    ReturnResponseDTO response =
	            returnService.getReturnById(
	                    "RET_001",
	                    instructorUser
	            );

	    assertNotNull(response);
	}
	
	@Test
	void getReturnById_adminAccess_success() {

	    when(returnRepository.findById("RET_001"))
	            .thenReturn(Optional.of(returnEntity));

	    ReturnResponseDTO response =
	            returnService.getReturnById(
	                    "RET_001",
	                    adminUser
	            );

	    assertNotNull(response);
	}
	
	@Test
	void getReturnById_studentForbidden() {

	    when(returnRepository.findById("RET_001"))
	            .thenReturn(Optional.of(returnEntity));

	    assertThrows(
	            UnauthorizedException.class,
	            () -> returnService.getReturnById(
	                    "RET_001",
	                    anotherStudent
	            )
	    );
	}
	
	@Test
	void getReturnById_notFound() {

	    when(returnRepository.findById("RET_001"))
	            .thenReturn(Optional.empty());

	    assertThrows(
	            ResourceNotFoundException.class,
	            () -> returnService.getReturnById(
	                    "RET_001",
	                    studentUser
	            )
	    );
	}
	
	@Test
	void getReturnById_inactiveUserForbidden() {

	    assertThrows(
	            UnauthorizedException.class,
	            () -> returnService.getReturnById(
	                    "RET_001",
	                    inactiveStudent
	            )
	    );

	    verify(returnRepository, never())
	            .findById(any());
	}
	
	@Test
	void getReturns_studentGetsOwnReturns() {

	    when(returnRepository.findByReturnedBy("STU_001"))
	            .thenReturn(List.of(returnEntity));

	    List<ReturnResponseDTO> responses =
	            returnService.getReturns(studentUser);

	    assertEquals(1, responses.size());

	    verify(returnRepository)
	            .findByReturnedBy("STU_001");

	    verify(returnRepository, never())
	            .findAll();
	}
	
	@Test
	void getReturns_instructorGetsAllReturns() {

	    when(returnRepository.findAll())
	            .thenReturn(List.of(returnEntity));

	    List<ReturnResponseDTO> responses =
	            returnService.getReturns(instructorUser);

	    assertEquals(1, responses.size());

	    verify(returnRepository)
	            .findAll();
	}
	
	@Test
	void getReturns_adminGetsAllReturns() {

	    when(returnRepository.findAll())
	            .thenReturn(List.of(returnEntity));

	    List<ReturnResponseDTO> responses =
	            returnService.getReturns(adminUser);

	    assertEquals(1, responses.size());

	    verify(returnRepository)
	            .findAll();
	}
	
	@Test
	void getReturns_inactiveUserForbidden() {

	    assertThrows(
	            UnauthorizedException.class,
	            () -> returnService.getReturns(
	                    inactiveStudent
	            )
	    );

	    verify(returnRepository, never())
	            .findAll();

	    verify(returnRepository, never())
	            .findByReturnedBy(any());
	}
	
	@Test
	void getReturnsByIssue_studentOwnReturns_success() {

	    when(returnRepository.findByIssueId("ISSUE_1"))
	            .thenReturn(List.of(returnEntity));

	    List<ReturnResponseDTO> responses =
	            returnService.getReturnsByIssue(
	                    "ISSUE_1",
	                    studentUser
	            );

	    assertEquals(1, responses.size());
	}
	
	@Test
	void getReturnsByIssue_studentForbidden() {

	    when(returnRepository.findByIssueId("ISSUE_1"))
	            .thenReturn(List.of(returnEntity));

	    assertThrows(
	            UnauthorizedException.class,
	            () -> returnService.getReturnsByIssue(
	                    "ISSUE_1",
	                    anotherStudent
	            )
	    );
	}
	
	@Test
	void getReturnsByIssue_instructorAccess_success() {

	    when(returnRepository.findByIssueId("ISSUE_1"))
	            .thenReturn(List.of(returnEntity));

	    List<ReturnResponseDTO> responses =
	            returnService.getReturnsByIssue(
	                    "ISSUE_1",
	                    instructorUser
	            );

	    assertEquals(1, responses.size());
	}
	
	@Test
	void getReturnsByIssue_emptyList() {

	    when(returnRepository.findByIssueId("ISSUE_1"))
	            .thenReturn(List.of());

	    List<ReturnResponseDTO> responses =
	            returnService.getReturnsByIssue(
	                    "ISSUE_1",
	                    studentUser
	            );

	    assertTrue(responses.isEmpty());
	}
	
	@Test
	void getReturnsByIssue_inactiveUserForbidden() {

	    assertThrows(
	            UnauthorizedException.class,
	            () -> returnService.getReturnsByIssue(
	                    "ISSUE_1",
	                    inactiveStudent
	            )
	    );

	    verify(returnRepository, never())
	            .findByIssueId(any());
	}
	
}
