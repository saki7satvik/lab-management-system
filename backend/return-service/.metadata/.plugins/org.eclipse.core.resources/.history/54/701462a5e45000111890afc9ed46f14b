package com.return_service.service;

import java.util.List;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import com.return_service.dto.CurrentUser;
import com.return_service.dto.external.IssueItemDTO;
import com.return_service.dto.external.IssueResponseDTO;
import com.return_service.enums.IssueStatus;
import com.return_service.enums.Role;
import com.return_service.enums.Status;
import com.return_service.repository.ReturnRepository;
import com.return_service.service.impl.ReturnServiceImpl;

@ExtendWith(MockitoExtension.class)
public class ProcessReturnTests {
	@Mock
	private ReturnRepository returnRepository;
	
	@Mock
	private InventoryClient inventoryClient;
	
	@Mock
	private IssueClient issueClient;
	
	@InjectMocks
	private ReturnServiceImpl returnService;
	
	private CurrentUser instructorUser;
	private CurrentUser studentUser;
	private CurrentUser inactiveInstructor;

	private IssueResponseDTO issue;
	private IssueItemDTO issueItem1;
	private IssueItemDTO issueItem2;
	
	@BeforeEach
	void setUp() {

	    instructorUser = CurrentUser.builder()
	            .id("INS_001")
	            .role(Role.INSTRUCTOR)
	            .status(Status.ACTIVE)
	            .build();

	    inactiveInstructor = CurrentUser.builder()
	            .id("INS_002")
	            .role(Role.INSTRUCTOR)
	            .status(Status.INACTIVE)
	            .build();

	    studentUser = CurrentUser.builder()
	            .id("STU_001")
	            .role(Role.STUDENT)
	            .status(Status.ACTIVE)
	            .build();

	    issueItem1 = IssueItemDTO.builder()
	            .issueItemId("ITEM_1")
	            .componentId("COMP_1")
	            .quantityIssued(5)
	            .build();

	    issueItem2 = IssueItemDTO.builder()
	            .issueItemId("ITEM_2")
	            .componentId("COMP_2")
	            .quantityIssued(3)
	            .build();

	    issue = IssueResponseDTO.builder()
	            .IssueId("ISSUE_1")
	            .issuedBy("STU_001")
	            .status(IssueStatus.ISSUED)
	            .items(List.of(issueItem1, issueItem2))
	            .build();
	}
	

}
