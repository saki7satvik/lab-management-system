import org.springframework.transaction.annotation.Transactional;
import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class RequestServiceImpl implements RequestService{
	
	private final RequestRepository requestRepository;
	
    private final InventoryClient inventoryClient;
    
    @Override
    @Transactional
    public RequestResponseDTO createRequest(CreateRequestDTO dto, String collegeId) {

        // 🔒 1. Validate items not empty
        if (dto.getItems() == null || dto.getItems().isEmpty()) {
            throw new BadRequestException("Request must contain at least one item");
        }

        // 🔒 2. Extract component IDs
        List<String> componentIds = dto.getItems()
                .stream()
                .map(RequestItemDTO::getComponentId)
                .toList();

        // 🔒 3. Prevent duplicate components
        Set<String> uniqueIds = new HashSet<>(componentIds);
        if (uniqueIds.size() != componentIds.size()) {
            throw new BadRequestException("Duplicate components in request");
        }

        // 🔒 4. Validate components via Inventory Service
        Map<String, Boolean> existenceMap = inventoryClient.validateComponents(componentIds);

        // 🔒 5. Create Request (timestamps + status handled by entity)
        Request request = Request.builder()
                .createdBy(collegeId)
                .targetType(dto.getTargetType())
                .targetId(dto.getTargetId())
                .build();

        // 🔒 6. Add items (using helper → ensures bidirectional mapping)
        for (RequestItemDTO itemDTO : dto.getItems()) {

            // ❌ Component does not exist
            if (!existenceMap.getOrDefault(itemDTO.getComponentId(), false)) {
                throw new BadRequestException("Component not found: " + itemDTO.getComponentId());
            }

            // ❌ Invalid quantity
            if (itemDTO.getQuantity() <= 0) {
                throw new BadRequestException("Quantity must be greater than zero");
            }

            RequestItem item = RequestItem.builder()
                    .componentId(itemDTO.getComponentId())
                    .quantityRequested(itemDTO.getQuantity())
                    .quantityApproved(0)
                    .status(RequestItemStatus.PENDING)
                    .build();

            request.addItem(item); // 🔥 critical
        }

        // 🔒 7. Persist
        requestRepository.save(request);

        return mapToResponse(request);
    }

    // =================== GET ===================
    @Override
    public RequestResponseDTO getRequestById(String requestId, String currentUserId) {

        Request request = requestRepository.findById(requestId)
                .orElseThrow(() -> new ResourceNotFoundException("Request not found"));

        // 🔒 Access control
        if (!request.getCreatedBy().equals(currentUserId)) {
            // Only owner OR instructor/admin can view
            if (!isPrivilegedUser(currentUserId)) {
                throw new UnauthorizedException("Access denied");
            }
        }

        return mapToResponse(request);
    }

    @Override
    public List<RequestResponseDTO> getRequestsByUser(String targetUserId, String currentUserId) {

        // 🔒 Students can only see their own requests
        if (!targetUserId.equals(currentUserId) && !isPrivilegedUser(currentUserId)) {
            throw new UnauthorizedException("Access denied");
        }

        return requestRepository.findByCreatedBy(targetUserId)
                .stream()
                .map(this::mapToResponse)
                .toList();
    }

    @Override
    public List<RequestResponseDTO> getAllRequests(String currentUserId) {

        // 🔒 Only admin/instructor allowed
        if (!isPrivilegedUser(currentUserId)) {
            throw new UnauthorizedException("Access denied");
        }

        return requestRepository.findAll()
                .stream()
                .map(this::mapToResponse)
                .toList();
    }
    
    // ================= APPROVE =================
    
    @Override
    @Transactional
    public RequestResponseDTO approveRequest(String requestId,
                                             ApproveRequestDTO dto,
                                             String instructorId) {

        // 🔒 1. Fetch request
        Request request = requestRepository.findById(requestId)
                .orElseThrow(() -> new ResourceNotFoundException("Request not found"));

        // 🔒 2. Only PENDING allowed
        if (request.getStatus() != RequestStatus.PENDING) {
            throw new ConflictException("Request already processed");
        }

        // 🔒 3. Validate DTO
        if (dto.getItems() == null || dto.getItems().isEmpty()) {
            throw new BadRequestException("Approval items cannot be empty");
        }

        // 🔒 4. Map approval input (prevent duplicates)
        Map<String, Integer> approvalMap = new HashMap<>();

        for (ApproveRequestItemDTO item : dto.getItems()) {

            if (approvalMap.containsKey(item.getRequestItemId())) {
                throw new BadRequestException("Duplicate request item in approval");
            }

            if (item.getQuantityApproved() < 0) {
                throw new BadRequestException("Approved quantity cannot be negative");
            }

            approvalMap.put(item.getRequestItemId(), item.getQuantityApproved());
        }

        // 🔒 5. Fetch availability from Inventory
        List<String> componentIds = request.getItems()
                .stream()
                .map(RequestItem::getComponentId)
                .toList();

        Map<String, Integer> availabilityMap =
                inventoryClient.getAvailableQuantities(componentIds);

        // 🔒 6. Process each item
        for (RequestItem item : request.getItems()) {

            int approvedQty = approvalMap.getOrDefault(item.getId(), 0);
            int requestedQty = item.getQuantityRequested();
            int availableQty = availabilityMap.getOrDefault(item.getComponentId(), 0);

            // ❌ validations
            if (approvedQty > requestedQty) {
                throw new ConflictException("Approved quantity exceeds requested");
            }

            if (approvedQty > availableQty) {
                throw new ConflictException("Approved quantity exceeds available stock");
            }

            // ✅ set approved qty
            item.setQuantityApproved(approvedQty);

            // 🔥 status logic
            if (approvedQty == 0) {
                item.setStatus(RequestItemStatus.REJECTED);
            } else if (approvedQty < requestedQty) {
                item.setStatus(RequestItemStatus.PARTIAL);
            } else {
                item.setStatus(RequestItemStatus.APPROVED);
            }
        }

        // 🔒 7. Update request status
        updateRequestStatus(request);

        return mapToResponse(request);
    }
	
	// ================= REJECT =================
	
	@Override
    @Transactional
    public RequestResponseDTO rejectRequest(String requestId, String instructorId) {

        Request request = requestRepository.findById(requestId)
                .orElseThrow(() -> new BadRequestException("Request not found"));
        
        UserDTO instructor = userClient.getUserByCollegeId(instructorId);

        if (instructor == null || !"INSTRUCTOR".equals(instructor.getRole())) {
            throw new UnauthorizedException("Only instructor can reject");
        }
        
        if (request.getStatus() != RequestStatus.PENDING) {
            throw new ConflictException("Request already processed");
        }
        
        request.setStatus(RequestStatus.REJECTED);

        request.getItems().forEach(i -> {
            i.setStatus(RequestItemStatus.REJECTED);
            i.setQuantityApproved(0);
        });

        return mapToResponse(request);
    }
	
	// ================= HELPER =================

    private void updateRequestStatus(Request request) {

        boolean allApproved = true;
        boolean anyApproved = false;

        for (RequestItem item : request.getItems()) {

            if (item.getStatus() != RequestItemStatus.APPROVED) {
                allApproved = false;
            }

            if (item.getQuantityApproved() > 0) {
                anyApproved = true;
            }
        }

        if (allApproved) {
            request.setStatus(RequestStatus.APPROVED);
        } else if (anyApproved) {
            request.setStatus(RequestStatus.PARTIALLY_APPROVED);
        } else {
            request.setStatus(RequestStatus.REJECTED);
        }
    }

    private RequestResponseDTO mapToResponse(Request request) {

        List<RequestItemResponseDTO> items =
                request.getItems().stream()
                        .map(i -> RequestItemResponseDTO.builder()
                                .id(i.getId())
                                .componentId(i.getComponentId())
                                .quantityRequested(i.getQuantityRequested())
                                .quantityApproved(i.getQuantityApproved())
                                .status(i.getStatus())
                                .build())
                        .toList();

        return RequestResponseDTO.builder()
                .id(request.getId())
                .createdBy(request.getCreatedBy())
                .targetType(request.getTargetType())
                .targetId(request.getTargetId())
                .status(request.getStatus())
                .createdAt(request.getCreatedAt())
                .updatedAt(request.getUpdatedAt())
                .items(items)
                .build();
    }
    
    private boolean isPrivilegedUser(String currentUserId) {
        Authentication auth = SecurityContextHolder.getContext().getAuthentication();

        return auth.getAuthorities().stream()
                .anyMatch(a ->
                        a.getAuthority().equals("ROLE_ADMIN") ||
                        a.getAuthority().equals("ROLE_INSTRUCTOR")
                );
    }

}
