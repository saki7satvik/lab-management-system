package com.request_service.controller;

import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;


import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.post;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.put;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.jsonPath;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.status;

import java.util.List;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.context.annotation.Import;
import org.springframework.http.MediaType;
import org.springframework.test.context.bean.override.mockito.MockitoBean;
import org.springframework.test.web.servlet.MockMvc;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.request_service.config.SecurityConfig;
import com.request_service.dto.request.ApproveRequestDTO;
import com.request_service.dto.request.ApproveRequestItemDTO;
import com.request_service.dto.request.CreateRequestDTO;
import com.request_service.dto.request.RequestItemDTO;
import com.request_service.dto.response.CurrentUser;
import com.request_service.dto.response.RequestResponseDTO;
import com.request_service.enums.Role;
import com.request_service.enums.Status;
import com.request_service.enums.TargetType;
import com.request_service.security.CustomAccessDeniedHandler;
import com.request_service.security.CustomAuthenticationEntryPoint;
import com.request_service.security.JwtFilter;
import com.request_service.security.JwtUtil;
import com.request_service.service.RequestService;

@WebMvcTest(RequestController.class)
@Import({
    SecurityConfig.class,
    JwtFilter.class,
    JwtUtil.class,
    CustomAccessDeniedHandler.class,
    CustomAuthenticationEntryPoint.class
})
public class RequestControllerTests {
	
	@Autowired
	private MockMvc mockMvc;

	@Autowired
	private ObjectMapper objectMapper;

	@MockitoBean
	private RequestService requestService;

	@MockitoBean
	private JwtUtil jwtUtil;
	
	private String instructorToken;
	private String studentToken;
	
	
	@BeforeEach
	void setUp() {

	    instructorToken = "Bearer instructor-token";
	    studentToken = "Bearer student-token";
	}
	
	private void mockStudentJwt() {

	    when(jwtUtil.extractCollegeId("student-token"))
	            .thenReturn("STU_001");

	    when(jwtUtil.extractRole("student-token"))
	            .thenReturn(Role.STUDENT.name());

	    when(jwtUtil.extractStatus("student-token"))
	            .thenReturn(Status.ACTIVE.name());

	    when(jwtUtil.isTokenValid("student-token"))
	            .thenReturn(true);
	}
	
	private void mockInstructorJwt() {

	    when(jwtUtil.extractCollegeId("instructor-token"))
	            .thenReturn("INS_001");

	    when(jwtUtil.extractRole("instructor-token"))
	            .thenReturn(Role.INSTRUCTOR.name());

	    when(jwtUtil.extractStatus("instructor-token"))
	            .thenReturn(Status.ACTIVE.name());

	    when(jwtUtil.isTokenValid("instructor-token"))
	            .thenReturn(true);
	}
	
	@Test
	void createRequest_success() throws Exception {

	    CreateRequestDTO dto = CreateRequestDTO.builder()
	            .targetType(TargetType.INDIVIDUAL)
	            .targetId("STU_001")
	            .items(List.of(
	                    new RequestItemDTO("COMP_1", 2)
	            ))
	            .build();

	    RequestResponseDTO response =
	            RequestResponseDTO.builder()
	                    .id("REQ_1")
	                    .build();

	    mockStudentJwt();

	    when(requestService.createRequest(
	            any(CreateRequestDTO.class),
	            any(CurrentUser.class)
	    )).thenReturn(response);

	    mockMvc.perform(post("/requests")
	                    .header("Authorization", studentToken)
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(objectMapper.writeValueAsString(dto)))
	            .andExpect(status().isOk())
	            .andExpect(jsonPath("$.id")
	                    .value("REQ_1"));

	    verify(requestService)
	            .createRequest(
	                    any(CreateRequestDTO.class),
	                    any(CurrentUser.class)
	            );
	}
	
	@Test
	void createRequest_noToken_unauthorized() throws Exception {

	    CreateRequestDTO dto = CreateRequestDTO.builder()
	            .build();

	    mockMvc.perform(post("/requests")
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(objectMapper.writeValueAsString(dto)))
	            .andExpect(status().isUnauthorized());

	    verify(requestService, never())
	            .createRequest(any(), any());
	}
	
	@Test
	void createRequest_forbiddenRole() throws Exception {

	    when(jwtUtil.extractCollegeId("admin-token"))
	            .thenReturn("ADM_001");

	    when(jwtUtil.extractRole("admin-token"))
	            .thenReturn(Role.SUPER_ADMIN.name());

	    when(jwtUtil.extractStatus("admin-token"))
	            .thenReturn(Status.ACTIVE.name());

	    when(jwtUtil.isTokenValid("admin-token"))
	            .thenReturn(true);

	    CreateRequestDTO dto =
	            CreateRequestDTO.builder().build();

	    mockMvc.perform(post("/requests")
	                    .header(
	                            "Authorization",
	                            "Bearer admin-token"
	                    )
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(objectMapper.writeValueAsString(dto)))
	            .andExpect(status().isForbidden());

	    verify(requestService, never())
	            .createRequest(any(), any());
	}
	
	@Test
	void getMyRequests_success() throws Exception {

	    mockStudentJwt();

	    when(requestService.getRequestsByUser(
	            eq("STU_001"),
	            any(CurrentUser.class)
	    )).thenReturn(List.of());

	    mockMvc.perform(get("/requests/user")
	                    .header("Authorization", studentToken))
	            .andExpect(status().isOk());

	    verify(requestService)
	            .getRequestsByUser(
	                    eq("STU_001"),
	                    any(CurrentUser.class)
	            );
	}
	
	@Test
	void getAllRequests_success() throws Exception {

	    mockInstructorJwt();

	    when(requestService.getAllRequests(
	            any(CurrentUser.class)
	    )).thenReturn(List.of());

	    mockMvc.perform(get("/requests")
	                    .header("Authorization", instructorToken))
	            .andExpect(status().isOk());

	    verify(requestService)
	            .getAllRequests(any(CurrentUser.class));
	}
	
	@Test
	void getAllRequests_studentForbidden() throws Exception {

	    mockStudentJwt();

	    mockMvc.perform(get("/requests")
	                    .header("Authorization", studentToken))
	            .andExpect(status().isForbidden());

	    verify(requestService, never())
	            .getAllRequests(any());
	}
	
	@Test
	void approveRequest_success() throws Exception {

	    mockInstructorJwt();

	    ApproveRequestDTO dto =
	            ApproveRequestDTO.builder()
	                    .items(List.of(
	                            new ApproveRequestItemDTO(
	                                    "ITEM_1",
	                                    2
	                            )
	                    ))
	                    .build();

	    when(requestService.approveRequest(
	            eq("REQ_1"),
	            any(ApproveRequestDTO.class),
	            any(CurrentUser.class)
	    )).thenReturn(
	            RequestResponseDTO.builder()
	                    .id("REQ_1")
	                    .build()
	    );

	    mockMvc.perform(put("/requests/REQ_1/approve")
	                    .header("Authorization", instructorToken)
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(objectMapper.writeValueAsString(dto)))
	            .andExpect(status().isOk());

	    verify(requestService)
	            .approveRequest(
	                    eq("REQ_1"),
	                    any(),
	                    any()
	            );
	}
	
	@Test
	void approveRequest_studentForbidden() throws Exception {

	    mockStudentJwt();

	    ApproveRequestDTO dto =
	            ApproveRequestDTO.builder()
	                    .items(List.of())
	                    .build();

	    mockMvc.perform(put("/requests/REQ_1/approve")
	                    .header("Authorization", studentToken)
	                    .contentType(MediaType.APPLICATION_JSON)
	                    .content(objectMapper.writeValueAsString(dto)))
	            .andExpect(status().isForbidden());

	    verify(requestService, never())
	            .approveRequest(any(), any(), any());
	}
	
	@Test
	void rejectRequest_success() throws Exception {

	    mockInstructorJwt();

	    when(requestService.rejectRequest(
	            eq("REQ_1"),
	            any(CurrentUser.class)
	    )).thenReturn(
	            RequestResponseDTO.builder()
	                    .id("REQ_1")
	                    .build()
	    );

	    mockMvc.perform(put("/requests/REQ_1/reject")
	                    .header("Authorization", instructorToken))
	            .andExpect(status().isOk());

	    verify(requestService)
	            .rejectRequest(
	                    eq("REQ_1"),
	                    any(CurrentUser.class)
	            );
	}
	
	@Test
	void rejectRequest_studentForbidden() throws Exception {

	    mockStudentJwt();

	    mockMvc.perform(put("/requests/REQ_1/reject")
	                    .header("Authorization", studentToken))
	            .andExpect(status().isForbidden());

	    verify(requestService, never())
	            .rejectRequest(any(), any());
	}

}
