    @Override
    @Transactional
    public RequestResponseDTO createRequest(CreateRequestDTO dto, String userId) {

        // 1. Validate user
        UserDTO user = userClient.getUserByCollegeId(userId);
        if (user == null || !"ACTIVE".equals(user.getStatus())) {
            throw new RuntimeException("Invalid or inactive user");
        }

        // 2. Prepare validation request
        List<ComponentValidationRequestDTO> validationRequest =
                dto.getItems().stream()
                        .map(i -> new ComponentValidationRequestDTO(i.getComponentId(), i.getQuantity()))
                        .toList();

        // 3. Validate components (BULK)
        List<ComponentValidationResponseDTO> validationResponse =
                inventoryClient.validateComponents(validationRequest);

        Map<String, ComponentValidationResponseDTO> validationMap =
                validationResponse.stream()
                        .collect(Collectors.toMap(ComponentValidationResponseDTO::getComponentId, v -> v));

        // 4. Create Request
        Request request = Request.builder()
                .createdBy(userId)
                .targetType(dto.getTargetType())
                .targetId(dto.getTargetId())
                .status(RequestStatus.PENDING)
                .build();

        List<RequestItem> items = new ArrayList<>();

        for (RequestItemDTO itemDTO : dto.getItems()) {

            ComponentValidationResponseDTO validation =
                    validationMap.get(itemDTO.getComponentId());

            if (validation == null || !validation.isExists()) {
                throw new RuntimeException("Component not found: " + itemDTO.getComponentId());
            }

            RequestItem item = RequestItem.builder()
                    .request(request)
                    .componentId(itemDTO.getComponentId())
                    .quantityRequested(itemDTO.getQuantity())
                    .quantityApproved(0)
                    .status(RequestItemStatus.PENDING)
                    .build();

            items.add(item);
        }

        request.setItems(items);

        requestRepository.save(request);

        return mapToResponse(request);
    }


