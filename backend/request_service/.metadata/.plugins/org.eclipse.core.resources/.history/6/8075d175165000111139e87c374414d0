package com.request_service.service;

import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyList;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import com.request_service.dto.request.CreateRequestDTO;
import com.request_service.dto.request.RequestItemDTO;
import com.request_service.dto.response.CurrentUser;
import com.request_service.dto.response.RequestResponseDTO;
import com.request_service.entity.Request;
import com.request_service.enums.Role;
import com.request_service.enums.Status;
import com.request_service.enums.TargetType;
import com.request_service.exception.BadRequestException;
import com.request_service.exception.ServiceUnavailableException;
import com.request_service.repository.RequestRepository;
import com.request_service.service.impl.RequestServiceImpl;

@ExtendWith(MockitoExtension.class)
public class CreateRequestTest {
	@Mock
    private RequestRepository requestRepository;

    @Mock
    private InventoryClient inventoryClient;

    @InjectMocks
    private RequestServiceImpl requestService;

    private CurrentUser studentUser;
    
    @BeforeEach
    void setUp() {

        studentUser = CurrentUser.builder()
                .id("STU_001")
                .role(Role.STUDENT)
                .status(Status.ACTIVE)
                .build();
    }
    
    @Test
    void createRequest_success() {

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("STU_001")
                .items(List.of(
                        new RequestItemDTO("COMP_1", 2)
                ))
                .build();

        when(inventoryClient.validateComponents(anyList()))
                .thenReturn(Map.of("COMP_1", true));

        when(requestRepository.save(any(Request.class)))
                .thenAnswer(invocation -> invocation.getArgument(0));

        RequestResponseDTO response =
                requestService.createRequest(dto, studentUser);

        assertNotNull(response);

        verify(requestRepository).save(any(Request.class));
    }
    
    @Test
    void createRequest_inactiveUser() {

        CurrentUser inactiveUser = CurrentUser.builder()
                .id("STU_001")
                .role(Role.STUDENT)
                .status(Status.INACTIVE)
                .build();

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .items(List.of(
                        new RequestItemDTO("COMP_1", 1)
                ))
                .build();

        assertThrows(
                UnauthorizedException.class,
                () -> requestService.createRequest(dto, inactiveUser)
        );

        verify(requestRepository, never())
                .save(any());
    }

    @Test
    void createRequest_invalidRole() {

        CurrentUser invalidUser = CurrentUser.builder()
                .id("USER_001")
                .role(Role.SUPER_ADMIN)
                .status(Status.ACTIVE)
                .build();

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("USER_001")
                .items(List.of(
                        new RequestItemDTO("COMP_1", 1)
                ))
                .build();

        assertThrows(
                UnauthorizedException.class,
                () -> requestService.createRequest(dto, invalidUser)
        );

        verify(requestRepository, never())
                .save(any());
    }

    @Test
    void createRequest_targetSpoofing() {

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("STU_999")
                .items(List.of(
                        new RequestItemDTO("COMP_1", 1)
                ))
                .build();

        assertThrows(
                UnauthorizedException.class,
                () -> requestService.createRequest(dto, studentUser)
        );

        verify(requestRepository, never())
                .save(any());
    }

    @Test
    void createRequest_emptyItems() {

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("STU_001")
                .items(List.of())
                .build();

        assertThrows(
                BadRequestException.class,
                () -> requestService.createRequest(dto, studentUser)
        );

        verify(requestRepository, never())
                .save(any());
    }

    @Test
    void createRequest_duplicateComponents() {

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("STU_001")
                .items(List.of(
                        new RequestItemDTO("COMP_1", 1),
                        new RequestItemDTO("COMP_1", 2)
                ))
                .build();

        assertThrows(
                BadRequestException.class,
                () -> requestService.createRequest(dto, studentUser)
        );

        verify(requestRepository, never())
                .save(any());
    }

    @Test
    void createRequest_invalidQuantity() {

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("STU_001")
                .items(List.of(
                        new RequestItemDTO("COMP_1", 0)
                ))
                .build();

        assertThrows(
                BadRequestException.class,
                () -> requestService.createRequest(dto, studentUser)
        );

        verify(requestRepository, never())
                .save(any());
    }

    @Test
    void createRequest_blankComponentId() {

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("STU_001")
                .items(List.of(
                        new RequestItemDTO("", 1)
                ))
                .build();

        assertThrows(
                BadRequestException.class,
                () -> requestService.createRequest(dto, studentUser)
        );

        verify(requestRepository, never())
                .save(any());
    }

    @Test
    void createRequest_inventoryServiceFailure() {

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("STU_001")
                .items(List.of(
                        new RequestItemDTO("COMP_1", 1)
                ))
                .build();

        when(inventoryClient.validateComponents(anyList()))
                .thenThrow(new RuntimeException());

        assertThrows(
                ServiceUnavailableException.class,
                () -> requestService.createRequest(dto, studentUser)
        );

        verify(requestRepository, never())
                .save(any());
    }

    @Test
    void createRequest_componentNotFound() {

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("STU_001")
                .items(List.of(
                        new RequestItemDTO("COMP_1", 1)
                ))
                .build();

        when(inventoryClient.validateComponents(anyList()))
                .thenReturn(Map.of("COMP_1", false));

        assertThrows(
                BadRequestException.class,
                () -> requestService.createRequest(dto, studentUser)
        );

        verify(requestRepository, never())
                .save(any());
    }

    @Test
    void createRequest_tooManyItems() {

        List<RequestItemDTO> items = new ArrayList<>();

        for (int i = 0; i < 51; i++) {
            items.add(new RequestItemDTO("COMP_" + i, 1));
        }

        CreateRequestDTO dto = CreateRequestDTO.builder()
                .targetType(TargetType.INDIVIDUAL)
                .targetId("STU_001")
                .items(items)
                .build();

        assertThrows(
                BadRequestException.class,
                () -> requestService.createRequest(dto, studentUser)
        );

        verify(requestRepository, never())
                .save(any());
    }
}
