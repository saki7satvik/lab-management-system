package com.request_service.service.impl;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

import org.springframework.stereotype.Service;
import com.request_service.dto.external.UserDTO;
import com.request_service.dto.request.ApproveRequestDTO;
import com.request_service.dto.request.ApproveRequestItemDTO;
import com.request_service.dto.request.CreateRequestDTO;
import com.request_service.dto.request.RequestItemDTO;
import com.request_service.dto.response.RequestItemResponseDTO;
import com.request_service.dto.response.RequestResponseDTO;
import com.request_service.entity.Request;
import com.request_service.entity.RequestItem;
import com.request_service.enums.RequestItemStatus;
import com.request_service.enums.RequestStatus;
import com.request_service.repository.RequestRepository;
import com.request_service.service.InventoryClient;
import com.request_service.service.RequestService;
import com.request_service.service.UserClient;

import jakarta.transaction.Transactional;
import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class RequestServiceImpl implements RequestService{
	
	private final RequestRepository requestRepository;
	
	// External clients (you'll implement using RestTemplate/WebClient)
    private final UserClient userClient;
    private final InventoryClient inventoryClient;
    
    @Override
    @Transactional
    public RequestResponseDTO createRequest(CreateRequestDTO dto, String userId) {

        // 1. Validate user
        UserDTO user = userClient.getUserByCollegeId(userId);
        if (user == null || !"ACTIVE".equals(user.getStatus())) {
            throw new RuntimeException("Invalid or inactive user");
        }

        // 2. Validate component existence (NOT stock)
        List<String> componentIds = dto.getItems()
                .stream()
                .map(RequestItemDTO::getComponentId)
                .toList();
        Map<String, Boolean> existenceMap = inventoryClient.validateComponents(componentIds);
        
        // 3. Create Request
        Request request = Request.builder()
                .createdBy(userId)
                .targetType(dto.getTargetType())
                .targetId(dto.getTargetId())
                .status(RequestStatus.PENDING)
                .build();

        List<RequestItem> items = new ArrayList<>();

        for (RequestItemDTO itemDTO : dto.getItems()) {

        	if (!existenceMap.getOrDefault(itemDTO.getComponentId(), false)) {
                throw new RuntimeException("Component not found: " + itemDTO.getComponentId());
            }

            RequestItem item = RequestItem.builder()
                    .request(request)
                    .componentId(itemDTO.getComponentId())
                    .quantityRequested(itemDTO.getQuantity())
                    .quantityApproved(0)
                    .status(RequestItemStatus.PENDING)
                    .build();

            items.add(item);
        }

        request.setItems(items);

        requestRepository.save(request);

        return mapToResponse(request);
    }

    // =================== GET ===================
    @Override
    public RequestResponseDTO getRequestById(String requestId) {
        Request request = requestRepository.findById(requestId)
                .orElseThrow(() -> new RuntimeException("Request not found"));

        return mapToResponse(request);
    }

    @Override
    public List<RequestResponseDTO> getRequestsByUser(String userId) {
        return requestRepository.findByCreatedBy(userId)
                .stream()
                .map(this::mapToResponse)
                .toList();
    }

    @Override
    public List<RequestResponseDTO> getAllRequests() {
        return requestRepository.findAll()
                .stream()
                .map(this::mapToResponse)
                .toList();
    }
    
    // ================= APPROVE =================
    
	@Override
    @Transactional
    public RequestResponseDTO approveRequest(String requestId, ApproveRequestDTO dto, String instructorId) {
		
		// 1. Validate RequestId
        Request request = requestRepository.findById(requestId)
                .orElseThrow(() -> new RuntimeException("Request not found"));

        // 2. Validate instructor
        UserDTO instructor = userClient.getUserByCollegeId(instructorId);
        if (instructor == null || !"INSTRUCTOR".equals(instructor.getRole())) {
            throw new RuntimeException("Only instructor can approve requests");
        }

        // 2. Fetch availability
        List<String> componentIds = request.getItems()
                .stream()
                .map(RequestItem::getComponentId)
                .toList();

        // 3. Map approval input
        Map<String, Integer> approvalMap = dto.getItems()
                .stream()
                .collect(Collectors.toMap(
                        ApproveRequestItemDTO::getRequestItemId,
                        ApproveRequestItemDTO::getQuantityApproved
                ));
        
        for (RequestItem item : request.getItems()) {

            ApproveRequestItemDTO approveDTO = approvalMap.get(item.getId());

            if (approveDTO == null) continue;

            int approvedQty = approveDTO.getQuantityApproved();

            if (approvedQty > item.getQuantityRequested()) {
                throw new RuntimeException("Approved quantity exceeds requested");
            }

            item.setQuantityApproved(approvedQty);

            if (approvedQty == 0) {
                item.setStatus(RequestItemStatus.REJECTED);
            } else if (approvedQty < item.getQuantityRequested()) {
                item.setStatus(RequestItemStatus.PARTIAL);
            } else {
                item.setStatus(RequestItemStatus.APPROVED);
            }
        }

        updateRequestStatus(request);

        return mapToResponse(request);
    }
	
	// ================= REJECT =================
	
	@Override
    @Transactional
    public RequestResponseDTO rejectRequest(String requestId, String instructorId) {

        Request request = requestRepository.findById(requestId)
                .orElseThrow(() -> new RuntimeException("Request not found"));

        request.setStatus(RequestStatus.REJECTED);

        request.getItems().forEach(i -> {
            i.setStatus(RequestItemStatus.REJECTED);
            i.setQuantityApproved(0);
        });

        return mapToResponse(request);
    }
	
	// ================= HELPER =================

    private void updateRequestStatus(Request request) {

        boolean allApproved = true;
        boolean anyApproved = false;

        for (RequestItem item : request.getItems()) {

            if (item.getStatus() != RequestItemStatus.APPROVED) {
                allApproved = false;
            }

            if (item.getQuantityApproved() > 0) {
                anyApproved = true;
            }
        }

        if (allApproved) {
            request.setStatus(RequestStatus.APPROVED);
        } else if (anyApproved) {
            request.setStatus(RequestStatus.PARTIALLY_APPROVED);
        } else {
            request.setStatus(RequestStatus.REJECTED);
        }
    }

    private RequestResponseDTO mapToResponse(Request request) {

        List<RequestItemResponseDTO> items =
                request.getItems().stream()
                        .map(i -> RequestItemResponseDTO.builder()
                                .id(i.getId())
                                .componentId(i.getComponentId())
                                .quantityRequested(i.getQuantityRequested())
                                .quantityApproved(i.getQuantityApproved())
                                .status(i.getStatus())
                                .build())
                        .toList();

        return RequestResponseDTO.builder()
                .id(request.getId())
                .createdBy(request.getCreatedBy())
                .targetType(request.getTargetType())
                .targetId(request.getTargetId())
                .status(request.getStatus())
                .createdAt(request.getCreatedAt())
                .updatedAt(request.getUpdatedAt())
                .items(items)
                .build();
    }

}
