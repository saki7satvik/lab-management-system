package com.inventory_service.service.impl;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import org.springframework.stereotype.Service;

import com.inventory_service.dto.UpdateStockDTO;
import com.inventory_service.dto.request.BulkStockUpdateDTO;
import com.inventory_service.dto.request.CreateComponentDTO;
import com.inventory_service.dto.request.StockUpdateItemDTO;
import com.inventory_service.dto.response.ComponentResponseDTO;
import com.inventory_service.dto.response.StockUpdateResponseDTO;
import com.inventory_service.entity.Component;
import com.inventory_service.entity.ComponentHistory;
import com.inventory_service.enums.ActionType;
import com.inventory_service.exception.BadRequestException;
import com.inventory_service.exception.ConflictException;
import com.inventory_service.exception.ResourceNotFoundException;
import com.inventory_service.repository.ComponentHistoryRepository;
import com.inventory_service.repository.InventoryRepository;
import com.inventory_service.service.InventoryService;

import jakarta.transaction.Transactional;
import lombok.RequiredArgsConstructor;

@RequiredArgsConstructor
@Service
public class InventoryServiceImpl implements InventoryService{
	
    private final InventoryRepository inventoryRepository;
	private final ComponentHistoryRepository componentHistoryRepository; 
    
    
    private void createHistory(Component component, String userId,
            ActionType action, int quantityChanged,
            String remarks) {

    	ComponentHistory history = new ComponentHistory();

    	history.setComponentId(component.getId());
    	history.setAction(action);
    	
    	if (action == ActionType.DEDUCT && quantityChanged > 0) {
    	    quantityChanged = -quantityChanged;
    	}
    	
    	history.setQuantityChanged(quantityChanged);

    	history.setTotalQuantityAfter(component.getTotalQuantity());
    	history.setAvailableQuantityAfter(component.getAvailableQuantity());

    	history.setPerformedBy(userId);
    	history.setRemarks(remarks);

    	componentHistoryRepository.save(history);
    }
    
    
    @Transactional
    @Override
    public ComponentResponseDTO createComponent(CreateComponentDTO dto, String performedBy) {

    	String name = dto.getName().trim();

    	if (inventoryRepository.existsByName(name)) {
    	    throw new ConflictException("Component already exists");
    	}

        Component component = new Component();
        component.setName(dto.getName().trim());
        component.setDescription(dto.getDescription());
        component.setTotalQuantity(dto.getTotalQuantity());
        component.setAvailableQuantity(dto.getTotalQuantity());
        component.setActive(true);

        component.setCreatedBy(performedBy);
        component.setUpdatedBy(performedBy);

        inventoryRepository.save(component);
        
        createHistory(
        	    component,
        	    performedBy,
        	    ActionType.CREATE,
        	    component.getTotalQuantity(),
        	    "Component created"
        	);

        return mapToDTO(component);
    }
    
    @Transactional
    @Override
    public ComponentResponseDTO increaseStock(UpdateStockDTO dto, String performedBy) {

        Component component = inventoryRepository.findById(dto.getComponentId())
                .orElseThrow(() -> new ResourceNotFoundException("Component not found"));

        if (!component.isActive()) {
            throw new ResourceNotFoundException("Component not found");
        }

        if (dto.getQuantity() <= 0) {
            throw new BadRequestException("Quantity must be greater than zero");
        }

        component.setTotalQuantity(component.getTotalQuantity() + dto.getQuantity());
        component.setAvailableQuantity(component.getAvailableQuantity() + dto.getQuantity());

        component.setUpdatedBy(performedBy);

        inventoryRepository.save(component);
        
        createHistory(
        	    component,
        	    performedBy,
        	    ActionType.INCREASE,
        	    dto.getQuantity(),
        	    "Stock increased"
        	);

        return mapToDTO(component);
    }
    
    @Transactional
    @Override
    public ComponentResponseDTO reduceStock(UpdateStockDTO dto, String performedBy) {

        Component component = inventoryRepository.findById(dto.getComponentId())
                .orElseThrow(() -> new ResourceNotFoundException("Component not found"));

        if (!component.isActive()) {
            throw new ResourceNotFoundException("Component not found");
        }

        int qty = dto.getQuantity();

        if (qty <= 0) {
            throw new BadRequestException("Quantity must be greater than zero");
        }

        if (component.getAvailableQuantity() < qty) {
            throw new ConflictException("Insufficient available stock");
        }

        component.setTotalQuantity(component.getTotalQuantity() - qty);
        component.setAvailableQuantity(component.getAvailableQuantity() - qty);

        component.setUpdatedBy(performedBy);

        inventoryRepository.save(component);
        
        createHistory(
        	    component,
        	    performedBy,
        	    ActionType.REDUCE,
        	    qty,
        	    "Stock reduced"
        	);

        return mapToDTO(component);
    }
  
    @Override
    public List<ComponentResponseDTO> getAllComponents() {

        return inventoryRepository.findAll().stream()
                .filter(Component::isActive)
                .map(this::mapToDTO)
                .toList();
    }
    
    @Override
    public ComponentResponseDTO getComponentById(String id) {

        Component component = inventoryRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("Component not found"));

        if (!component.isActive()) {
            throw new ResourceNotFoundException("Component not found");
        }

        return mapToDTO(component);
    }

    @Override
    public Map<String, Boolean> validateComponents(List<String> componentIds) {

        Map<String, Boolean> result = new HashMap<>();

        for (String id : componentIds) {
            boolean exists = inventoryRepository.findById(id)
                    .map(Component::isActive)
                    .orElse(false);

            result.put(id, exists);
        }

        return result;
    }
    
    @Override
    public Map<String, Integer> getAvailableQuantities(List<String> componentIds) {

        Map<String, Integer> result = new HashMap<>();

        for (String id : componentIds) {
            int available = inventoryRepository.findById(id)
                    .filter(Component::isActive)
                    .map(Component::getAvailableQuantity)
                    .orElse(0);

            result.put(id, available);
        }

        return result;
    }

    @Transactional
    @Override
    public List<StockUpdateResponseDTO> deductStock(BulkStockUpdateDTO request, String performedBy) {

        List<StockUpdateResponseDTO> response = new ArrayList<>();

        for (StockUpdateItemDTO item : request.getItems()) {

            Component component = inventoryRepository.findById(item.getComponentId())
                    .orElseThrow(() -> new ResourceNotFoundException("Component not found"));

            if (!component.isActive()) {
                throw new ResourceNotFoundException("Component not found");
            }

            if (component.getAvailableQuantity() < item.getQuantity()) {
                throw new ConflictException("Insufficient stock for component: " + component.getName());
            }

            component.setAvailableQuantity(
                    component.getAvailableQuantity() - item.getQuantity()
            );

            component.setUpdatedBy(performedBy);

            inventoryRepository.save(component);
            
            createHistory(
            	    component,
            	    performedBy,
            	    ActionType.DEDUCT,
            	    item.getQuantity(),
            	    "Bulk deduction"
            	);

            response.add(new StockUpdateResponseDTO(
                    component.getId(),
                    item.getQuantity(),
                    component.getAvailableQuantity()
            ));
        }

        return response;
    }
    
    

    @Transactional
	@Override
	public List<StockUpdateResponseDTO> addBackStock(BulkStockUpdateDTO request, String performedBy) {
		// TODO Auto-generated method stub
		List<StockUpdateResponseDTO> response = new ArrayList<>();

	    for (StockUpdateItemDTO item : request.getItems()) {

	        Component component = inventoryRepository.findById(item.getComponentId())
	                .orElseThrow(() -> new ResourceNotFoundException("Component not found"));

	        if (!component.isActive()) {
	            throw new ResourceNotFoundException("Component not found");
	        }

	        if (item.getQuantity() <= 0) {
	            throw new BadRequestException("Quantity must be greater than 0");
	        }

	        // 🔥 Core logic
	        component.setAvailableQuantity(
	                component.getAvailableQuantity() + item.getQuantity()
	        );

	        component.setUpdatedBy(performedBy);

	        inventoryRepository.save(component);

	        createHistory(
	                component,
	                performedBy,
	                ActionType.ADD_BACK,   // NEW ENUM
	                item.getQuantity(),
	                "Returned from return service"
	        );

	        response.add(new StockUpdateResponseDTO(
	                component.getId(),
	                item.getQuantity(),
	                component.getAvailableQuantity()
	        ));
	    }

	    return response;
	}
    
    private ComponentResponseDTO mapToDTO(Component component) {

    	return ComponentResponseDTO.builder()
    	        .id(component.getId())
    	        .name(component.getName())
    	        .description(component.getDescription())
    	        .totalQuantity(component.getTotalQuantity())
    	        .availableQuantity(component.getAvailableQuantity())
    	        .build();
    }
}

