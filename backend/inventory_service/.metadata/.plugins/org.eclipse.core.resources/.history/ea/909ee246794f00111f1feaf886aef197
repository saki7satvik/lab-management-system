package com.inventory_service.service;


import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

import java.util.List;
import java.util.Optional;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;

import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import com.inventory_service.dto.response.ComponentResponseDTO;
import com.inventory_service.entity.Component;
import com.inventory_service.enums.Status;
import com.inventory_service.exception.ResourceNotFoundException;
import com.inventory_service.repository.ComponentHistoryRepository;
import com.inventory_service.repository.InventoryRepository;
import com.inventory_service.service.impl.InventoryServiceImpl;

@ExtendWith(MockitoExtension.class)
class GetComponentTests {

    @Mock
    private InventoryRepository componentRepository;

    @Mock
    private ComponentHistoryRepository componentHistoryRepository;

    @InjectMocks
    private InventoryServiceImpl inventoryService;

    // =====================================================
    // TEST DATA FACTORY
    // =====================================================

    private Component component(
            String id,
            String name,
            boolean active
    ) {

        Component component =
                new Component();

        component.setId(id);
        component.setName(name);
        component.setDescription("Test Component");

        component.setTotalQuantity(10);
        component.setAvailableQuantity(8);

        component.setActive(active);

        return component;
    }

    // =====================================================
    // GET ALL COMPONENTS TESTS
    // =====================================================

    @Nested
    @DisplayName("Get All Components Tests")
    class GetAllComponentsTests {

        @Test
        @DisplayName("Should return only active components")
        void getAllComponents_success() {

            Component active1 =
                    component(
                            "COMP_001",
                            "ESP32",
                            true
                    );

            Component active2 =
                    component(
                            "COMP_002",
                            "Arduino",
                            true
                    );

            when(componentRepository.findByStatus(Status.ACTIVE))
                    .thenReturn(List.of(active1, active2));

            List<ComponentResponseDTO> response =
                    inventoryService.getAllComponents();

            assertNotNull(response);

            assertEquals(2, response.size());

            assertTrue(
                    response.stream()
                            .allMatch(
                                    c -> c.getStatus()
                                            == Status.ACTIVE
                            )
            );
        }

        @Test
        @DisplayName("Should return empty list when no active components exist")
        void getAllComponents_emptyList() {

            when(componentRepository.findByStatus(Status.ACTIVE))
                    .thenReturn(List.of());

            List<ComponentResponseDTO> response =
                    inventoryService.getAllComponents();

            assertNotNull(response);

            assertTrue(response.isEmpty());
        }

        @Test
        @DisplayName("Should never return inactive components")
        void getAllComponents_noInactiveComponents() {

            Component active =
                    component(
                            "COMP_001",
                            "ESP32",
                            Status.ACTIVE
                    );

            when(componentRepository.findByStatus(Status.ACTIVE))
                    .thenReturn(List.of(active));

            List<ComponentResponseDTO> response =
                    inventoryService.getAllComponents();

            assertEquals(1, response.size());

            assertTrue(
                    response.stream()
                            .noneMatch(
                                    c -> c.getStatus()
                                            == Status.INACTIVE
                            )
            );
        }

        @Test
        @DisplayName("Should map component fields correctly")
        void getAllComponents_mappingValidation() {

            Component component =
                    component(
                            "COMP_001",
                            "ESP32",
                            Status.ACTIVE
                    );

            when(componentRepository.findByStatus(Status.ACTIVE))
                    .thenReturn(List.of(component));

            List<ComponentResponseDTO> response =
                    inventoryService.getAllComponents();

            ComponentResponseDTO dto =
                    response.get(0);

            assertEquals("COMP_001", dto.getId());

            assertEquals("ESP32", dto.getName());

            assertEquals(
                    10,
                    dto.getTotalQuantity()
            );

            assertEquals(
                    8,
                    dto.getAvailableQuantity()
            );
        }
    }

    // =====================================================
    // GET COMPONENT BY ID TESTS
    // =====================================================

    @Nested
    @DisplayName("Get Component By Id Tests")
    class GetComponentByIdTests {

        @Test
        @DisplayName("Should return active component")
        void getComponentById_success() {

            Component component =
                    component(
                            "COMP_001",
                            "ESP32",
                            Status.ACTIVE
                    );

            when(componentRepository.findByIdAndStatus(
                    "COMP_001",
                    Status.ACTIVE
            )).thenReturn(Optional.of(component));

            ComponentResponseDTO response =
                    inventoryService.getComponentById(
                            "COMP_001"
                    );

            assertNotNull(response);

            assertEquals(
                    "COMP_001",
                    response.getId()
            );

            assertEquals(
                    "ESP32",
                    response.getName()
            );

            assertEquals(
                    Status.ACTIVE,
                    response.getStatus()
            );
        }

        @Test
        @DisplayName("Should throw exception when component not found")
        void getComponentById_notFound() {

            when(componentRepository.findByIdAndStatus(
                    "COMP_001",
                    Status.ACTIVE
            )).thenReturn(Optional.empty());

            ResourceNotFoundException ex =
                    assertThrows(
                            ResourceNotFoundException.class,
                            () -> inventoryService
                                    .getComponentById(
                                            "COMP_001"
                                    )
                    );

            assertEquals(
                    "Component not found",
                    ex.getMessage()
            );
        }

        @Test
        @DisplayName("Should treat inactive component as not found")
        void getComponentById_inactiveComponent() {

            when(componentRepository.findByIdAndStatus(
                    "COMP_001",
                    Status.ACTIVE
            )).thenReturn(Optional.empty());

            assertThrows(
                    ResourceNotFoundException.class,
                    () -> inventoryService
                            .getComponentById(
                                    "COMP_001"
                            )
            );
        }

        @Test
        @DisplayName("Should map component response correctly")
        void getComponentById_mappingValidation() {

            Component component =
                    component(
                            "COMP_001",
                            "Raspberry Pi",
                            Status.ACTIVE
                    );

            when(componentRepository.findByIdAndStatus(
                    "COMP_001",
                    Status.ACTIVE
            )).thenReturn(Optional.of(component));

            ComponentResponseDTO response =
                    inventoryService.getComponentById(
                            "COMP_001"
                    );

            assertEquals(
                    "COMP_001",
                    response.getId()
            );

            assertEquals(
                    "Raspberry Pi",
                    response.getName()
            );

            assertEquals(
                    "Test Component",
                    response.getDescription()
            );

            assertEquals(
                    10,
                    response.getTotalQuantity()
            );

            assertEquals(
                    8,
                    response.getAvailableQuantity()
            );
        }
    }
}
