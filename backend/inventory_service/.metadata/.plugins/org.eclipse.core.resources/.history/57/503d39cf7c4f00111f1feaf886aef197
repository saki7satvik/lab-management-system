package com.inventory_service.service;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

import java.util.List;
import java.util.Map;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;

import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import com.inventory_service.entity.Component;
import com.inventory_service.repository.InventoryRepository;
import com.inventory_service.repository.ComponentHistoryRepository;
import com.inventory_service.service.impl.InventoryServiceImpl;

@ExtendWith(MockitoExtension.class)
class ValidateTests {

    @Mock
    private InventoryRepository inventoryRepository;

    @Mock
    private ComponentHistoryRepository componentHistoryRepository;

    @InjectMocks
    private InventoryServiceImpl inventoryService;

    // =====================================================
    // TEST DATA FACTORY
    // =====================================================

    private Component component(
            String id,
            boolean active
    ) {

        Component component =
                new Component();

        component.setId(id);
        component.setName("Test");

        component.setActive(active);

        return component;
    }

    // =====================================================
    // TESTS
    // =====================================================

    @Nested
    @DisplayName("Validate Components Tests")
    class ValidateComponentsTests {

        @Test
        @DisplayName("Should validate active components")
        void validateComponents_success() {

            Component c1 =
                    component("COMP_001", true);

            Component c2 =
                    component("COMP_002", true);

            when(inventoryRepository.findAllById(
                    List.of("COMP_001", "COMP_002")
            )).thenReturn(List.of(c1, c2));

            Map<String, Boolean> result =
                    inventoryService.validateComponents(
                            List.of(
                                    "COMP_001",
                                    "COMP_002"
                            )
                    );

            assertEquals(2, result.size());

            assertTrue(result.get("COMP_001"));

            assertTrue(result.get("COMP_002"));
        }

        @Test
        @DisplayName("Should mark inactive component as false")
        void validateComponents_inactiveComponent() {

            Component c1 =
                    component("COMP_001", false);

            when(inventoryRepository.findAllById(
                    List.of("COMP_001")
            )).thenReturn(List.of(c1));

            Map<String, Boolean> result =
                    inventoryService.validateComponents(
                            List.of("COMP_001")
                    );

            assertFalse(result.get("COMP_001"));
        }

        @Test
        @DisplayName("Should mark missing component as false")
        void validateComponents_missingComponent() {

            when(inventoryRepository.findAllById(
                    List.of("COMP_001")
            )).thenReturn(List.of());

            Map<String, Boolean> result =
                    inventoryService.validateComponents(
                            List.of("COMP_001")
                    );

            assertFalse(result.get("COMP_001"));
        }

        @Test
        @DisplayName("Should return empty map for empty input")
        void validateComponents_emptyList() {

            when(inventoryRepository.findAllById(
                    List.of()
            )).thenReturn(List.of());

            Map<String, Boolean> result =
                    inventoryService.validateComponents(
                            List.of()
                    );

            assertTrue(result.isEmpty());
        }

        @Test
        @DisplayName("Should validate mixed component states")
        void validateComponents_mixedStates() {

            Component active =
                    component("COMP_001", true);

            Component inactive =
                    component("COMP_002", false);

            when(inventoryRepository.findAllById(
                    List.of(
                            "COMP_001",
                            "COMP_002",
                            "COMP_003"
                    )
            )).thenReturn(
                    List.of(active, inactive)
            );

            Map<String, Boolean> result =
                    inventoryService.validateComponents(
                            List.of(
                                    "COMP_001",
                                    "COMP_002",
                                    "COMP_003"
                            )
                    );

            assertTrue(result.get("COMP_001"));

            assertFalse(result.get("COMP_002"));

            assertFalse(result.get("COMP_003"));
        }
    }
}
