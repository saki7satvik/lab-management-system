package com.inventory_service.service;


import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

import java.util.Optional;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;

import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import com.inventory_service.dto.UpdateStockDTO;
import com.inventory_service.dto.response.ComponentResponseDTO;
import com.inventory_service.dto.response.CurrentUser;
import com.inventory_service.entity.Component;
import com.inventory_service.entity.ComponentHistory;
import com.inventory_service.enums.ActionType;
import com.inventory_service.enums.Role;
import com.inventory_service.enums.Status;
import com.inventory_service.exception.BadRequestException;
import com.inventory_service.exception.ResourceNotFoundException;
import com.inventory_service.exception.UnauthorizedException;
import com.inventory_service.repository.ComponentHistoryRepository;
import com.inventory_service.repository.InventoryRepository;
import com.inventory_service.service.impl.InventoryServiceImpl;

@ExtendWith(MockitoExtension.class)
class UpdateStockTests {

    @Mock
    private InventoryRepository inventoryRepository;

    @Mock
    private ComponentHistoryRepository componentHistoryRepository;

    @InjectMocks
    private InventoryServiceImpl inventoryService;

    // =====================================================
    // TEST DATA FACTORY
    // =====================================================

    private CurrentUser currentUser(
            Role role,
            Status status
    ) {

        return new CurrentUser(
                "INS_001",
                role,
                status
        );
    }

    private Component component(
            boolean active
    ) {

        Component component =
                new Component();

        component.setId("COMP_001");

        component.setName("ESP32");
        component.setDescription("Microcontroller");

        component.setTotalQuantity(10);
        component.setAvailableQuantity(8);

        component.setActive(active);

        return component;
    }

    private UpdateStockDTO updateDTO(
            int quantity
    ) {

        UpdateStockDTO dto =
                new UpdateStockDTO();

        dto.setComponentId("COMP_001");
        dto.setQuantity(quantity);

        return dto;
    }

    // =====================================================
    // INCREASE STOCK TESTS
    // =====================================================

    @Nested
    @DisplayName("Increase Stock Tests")
    class IncreaseStockTests {

        @Test
        @DisplayName("Should increase stock successfully")
        void increaseStock_success() {

            CurrentUser currentUser =
                    currentUser(
                            Role.INSTRUCTOR,
                            Status.ACTIVE
                    );

            UpdateStockDTO dto =
                    updateDTO(5);

            Component component =
                    component(true);

            when(inventoryRepository.findById("COMP_001"))
                    .thenReturn(Optional.of(component));

            when(inventoryRepository.save(any(Component.class)))
                    .thenAnswer(
                            invocation ->
                                    invocation.getArgument(0)
                    );

            ComponentResponseDTO response =
                    inventoryService.increaseStock(
                            dto,
                            currentUser
                    );

            assertNotNull(response);

            assertEquals(
                    15,
                    response.getTotalQuantity()
            );

            assertEquals(
                    13,
                    response.getAvailableQuantity()
            );

            verify(inventoryRepository)
                    .save(component);

            verify(componentHistoryRepository)
                    .save(any(ComponentHistory.class));
        }

        @Test
        @DisplayName("Should fail when current user is null")
        void increaseStock_nullUser() {

            UpdateStockDTO dto =
                    updateDTO(5);

            UnauthorizedException ex =
                    assertThrows(
                            UnauthorizedException.class,
                            () -> inventoryService
                                    .increaseStock(
                                            dto,
                                            null
                                    )
                    );

            assertEquals(
                    "User information is missing",
                    ex.getMessage()
            );

            verify(inventoryRepository, never())
                    .save(any());
        }

        @Test
        @DisplayName("Should deny non instructor")
        void increaseStock_accessDenied() {

            CurrentUser currentUser =
                    currentUser(
                            Role.STUDENT,
                            Status.ACTIVE
                    );

            UpdateStockDTO dto =
                    updateDTO(5);

            assertThrows(
                    UnauthorizedException.class,
                    () -> inventoryService
                            .increaseStock(
                                    dto,
                                    currentUser
                            )
            );

            verify(inventoryRepository, never())
                    .save(any());
        }

        @Test
        @DisplayName("Should deny inactive instructor")
        void increaseStock_inactiveInstructor() {

            CurrentUser currentUser =
                    currentUser(
                            Role.INSTRUCTOR,
                            Status.INACTIVE
                    );

            UpdateStockDTO dto =
                    updateDTO(5);

            assertThrows(
                    UnauthorizedException.class,
                    () -> inventoryService
                            .increaseStock(
                                    dto,
                                    currentUser
                            )
            );

            verify(inventoryRepository, never())
                    .save(any());
        }

        @Test
        @DisplayName("Should fail when component not found")
        void increaseStock_componentNotFound() {

            CurrentUser currentUser =
                    currentUser(
                            Role.INSTRUCTOR,
                            Status.ACTIVE
                    );

            UpdateStockDTO dto =
                    updateDTO(5);

            when(inventoryRepository.findById("COMP_001"))
                    .thenReturn(Optional.empty());

            ResourceNotFoundException ex =
                    assertThrows(
                            ResourceNotFoundException.class,
                            () -> inventoryService
                                    .increaseStock(
                                            dto,
                                            currentUser
                                    )
                    );

            assertEquals(
                    "Component not found",
                    ex.getMessage()
            );

            verify(inventoryRepository, never())
                    .save(any());
        }

        @Test
        @DisplayName("Should fail when component inactive")
        void increaseStock_inactiveComponent() {

            CurrentUser currentUser =
                    currentUser(
                            Role.INSTRUCTOR,
                            Status.ACTIVE
                    );

            UpdateStockDTO dto =
                    updateDTO(5);

            Component component =
                    component(false);

            when(inventoryRepository.findById("COMP_001"))
                    .thenReturn(Optional.of(component));

            assertThrows(
                    ResourceNotFoundException.class,
                    () -> inventoryService
                            .increaseStock(
                                    dto,
                                    currentUser
                            )
            );

            verify(inventoryRepository, never())
                    .save(any());
        }

        @Test
        @DisplayName("Should fail when quantity is zero")
        void increaseStock_zeroQuantity() {

            CurrentUser currentUser =
                    currentUser(
                            Role.INSTRUCTOR,
                            Status.ACTIVE
                    );

            UpdateStockDTO dto =
                    updateDTO(0);

            Component component =
                    component(true);

            when(inventoryRepository.findById("COMP_001"))
                    .thenReturn(Optional.of(component));

            BadRequestException ex =
                    assertThrows(
                            BadRequestException.class,
                            () -> inventoryService
                                    .increaseStock(
                                            dto,
                                            currentUser
                                    )
                    );

            assertEquals(
                    "Quantity must be greater than zero",
                    ex.getMessage()
            );

            verify(inventoryRepository, never())
                    .save(any());
        }

        @Test
        @DisplayName("Should fail when quantity is negative")
        void increaseStock_negativeQuantity() {

            CurrentUser currentUser =
                    currentUser(
                            Role.INSTRUCTOR,
                            Status.ACTIVE
                    );

            UpdateStockDTO dto =
                    updateDTO(-5);

            Component component =
                    component(true);

            when(inventoryRepository.findById("COMP_001"))
                    .thenReturn(Optional.of(component));

            assertThrows(
                    BadRequestException.class,
                    () -> inventoryService
                            .increaseStock(
                                    dto,
                                    currentUser
                            )
            );

            verify(inventoryRepository, never())
                    .save(any());
        }

        @Test
        @DisplayName("Should update updatedBy field")
        void increaseStock_updatedByValidation() {

            CurrentUser currentUser =
                    currentUser(
                            Role.INSTRUCTOR,
                            Status.ACTIVE
                    );

            UpdateStockDTO dto =
                    updateDTO(5);

            Component component =
                    component(true);

            when(inventoryRepository.findById("COMP_001"))
                    .thenReturn(Optional.of(component));

            when(inventoryRepository.save(any(Component.class)))
                    .thenAnswer(
                            invocation ->
                                    invocation.getArgument(0)
                    );

            inventoryService.increaseStock(
                    dto,
                    currentUser
            );

            assertEquals(
                    "INS_001",
                    component.getUpdatedBy()
            );
        }

        @Test
        @DisplayName("Should create history entry")
        void increaseStock_historyValidation() {

            CurrentUser currentUser =
                    currentUser(
                            Role.INSTRUCTOR,
                            Status.ACTIVE
                    );

            UpdateStockDTO dto =
                    updateDTO(5);

            Component component =
                    component(true);

            when(inventoryRepository.findById("COMP_001"))
                    .thenReturn(Optional.of(component));

            when(inventoryRepository.save(any(Component.class)))
                    .thenAnswer(
                            invocation ->
                                    invocation.getArgument(0)
                    );

            inventoryService.increaseStock(
                    dto,
                    currentUser
            );

            ArgumentCaptor<ComponentHistory> captor =
                    ArgumentCaptor.forClass(
                            ComponentHistory.class
                    );

            verify(componentHistoryRepository)
                    .save(captor.capture());

            ComponentHistory history =
                    captor.getValue();

            assertEquals(
                    ActionType.INCREASE,
                    history.getActionType()
            );

            assertEquals(
                    5,
                    history.getQuantity()
            );

            assertEquals(
                    "INS_001",
                    history.getPerformedBy()
            );
        }
    }
}
