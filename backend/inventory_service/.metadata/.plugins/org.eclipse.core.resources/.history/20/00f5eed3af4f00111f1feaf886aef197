    // =====================================================
    // TEST DATA FACTORY
    // =====================================================

    private UsernamePasswordAuthenticationToken mockAuth(
            Role role
    ) {

        CurrentUser currentUser =
                new CurrentUser(
                        "INS_001",
                        role,
                        Status.ACTIVE
                );

        return new UsernamePasswordAuthenticationToken(
                currentUser,
                null,
                List.of(
                        new SimpleGrantedAuthority(
                                "ROLE_" + role.name()
                        )
                )
        );
    }

    private CreateComponentDTO validCreateDTO() {

        CreateComponentDTO dto =
                new CreateComponentDTO();

        dto.setName("ESP32");
        dto.setDescription("Microcontroller");
        dto.setTotalQuantity(10);

        return dto;
    }

    private UpdateStockDTO validUpdateDTO() {

        UpdateStockDTO dto =
                new UpdateStockDTO();

        dto.setComponentId("COMP_001");
        dto.setQuantity(5);

        return dto;
    }

    private BulkStockUpdateDTO validBulkDTO() {

        StockUpdateItemDTO item =
                new StockUpdateItemDTO();

        item.setComponentId("COMP_001");
        item.setQuantity(2);

        BulkStockUpdateDTO dto =
                new BulkStockUpdateDTO();

        dto.setItems(List.of(item));

        return dto;
    }

    private ComponentResponseDTO responseDTO() {

        return ComponentResponseDTO.builder()
                .id("COMP_001")
                .name("ESP32")
                .description("Microcontroller")
                .totalQuantity(10)
                .availableQuantity(8)
                .build();
    }

    // =====================================================
    // CREATE COMPONENT
    // =====================================================

    @Test
    void createComponent_success() throws Exception {

        when(inventoryService.createComponent(any(), any()))
                .thenReturn(responseDTO());

        mockMvc.perform(
                post("/components")
                        .with(csrf())
                        .with(authentication(
                                mockAuth(Role.INSTRUCTOR)
                        ))
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(
                                objectMapper.writeValueAsString(
                                        validCreateDTO()
                                )
                        )
        )
        .andExpect(status().isOk())
        .andExpect(
                jsonPath("$.id")
                        .value("COMP_001")
        )
        .andExpect(
                jsonPath("$.name")
                        .value("ESP32")
        );

        verify(inventoryService)
                .createComponent(any(), any());
    }

    @Test
    void createComponent_forbidden() throws Exception {

        mockMvc.perform(
                post("/components")
                        .with(authentication(
                                mockAuth(Role.STUDENT)
                        ))
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(
                                objectMapper.writeValueAsString(
                                        validCreateDTO()
                                )
                        )
        )
        .andExpect(status().isForbidden());

        verify(inventoryService, never())
                .createComponent(any(), any());
    }

    @Test
    void createComponent_unauthorized() throws Exception {

        mockMvc.perform(
                post("/components")
                        .with(csrf())
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(
                                objectMapper.writeValueAsString(
                                        validCreateDTO()
                                )
                        )
        )
        .andExpect(status().isUnauthorized());

        verify(inventoryService, never())
                .createComponent(any(), any());
    }

    @Test
    void createComponent_invalidDTO() throws Exception {

        CreateComponentDTO dto =
                new CreateComponentDTO();

        mockMvc.perform(
                post("/components")
