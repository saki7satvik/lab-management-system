package com.inventory_service.service;

import java.util.List;
import java.util.Map;

import com.inventory_service.dto.UpdateStockDTO;
import com.inventory_service.dto.request.BulkStockUpdateDTO;
import com.inventory_service.dto.request.CreateComponentDTO;
import com.inventory_service.dto.response.ComponentResponseDTO;
import com.inventory_service.dto.response.CurrentUser;
import com.inventory_service.dto.response.StockUpdateResponseDTO;

public interface InventoryService {

    // 🔥 Create component (Instructor only)
    ComponentResponseDTO createComponent(CreateComponentDTO dto, CurrentUser currentUser);

    // 🔥 Increase stock
    ComponentResponseDTO increaseStock(UpdateStockDTO dto, CurrentUser currentUser);

    // 🔥 Reduce stock
    ComponentResponseDTO reduceStock(UpdateStockDTO dto, CurrentUser currentUser);

    // 🔥 Get all components
    List<ComponentResponseDTO> getAllComponents();

    // 🔥 Get by ID
    ComponentResponseDTO getComponentById(String id);

    // 🔥 Validate components (internal use)
    Map<String, Boolean> validateComponents(List<String> componentIds);

    // 🔥 Get availability (internal use)
    Map<String, Integer> getAvailableQuantities(List<String> componentIds);

    // 🔥 Deduct stock
    List<StockUpdateResponseDTO> deductStock(BulkStockUpdateDTO request, String performedBy);
    
    List<StockUpdateResponseDTO> addBackStock(BulkStockUpdateDTO request, String performedBy);
}
